{
    "class": "Class 10",
    "subject": "Mathematics",
    "chapter_name": "Real Numbers",
    "lesson_level": "Medium",
    "total_periods": 7,
    "period_duration_minutes": "40-45",
    "overall_learning_outcomes": [
        "Apply the Fundamental Theorem of Arithmetic confidently",
        "Solve HCF and LCM problems involving two or three numbers",
        "Use Euclid’s Division Algorithm independently",
        "Understand and write proofs for irrational numbers like √2, √3, √5",
        "Determine decimal expansion of rational numbers without division",
        "Solve word problems based on HCF and LCM"
    ],
    "lesson_plan": [
        {
            "period": 1,
            "title": "Fundamental Theorem of Arithmetic – Concept and Use",
            "topics_covered": [
                "Statement of Fundamental Theorem of Arithmetic",
                "Uniqueness of prime factorisation",
                "Writing numbers using powers of primes"
            ],
            "teaching_strategy": [
                "Quick recall of prime factorisation",
                "Discussion on uniqueness of factorisation",
                "Solved examples with larger numbers"
            ],
            "student_activities": [
                "Prime factorise 180, 360, and 420",
                "Write answers using powers of primes"
            ],
            "assessment": [
                "Short written problems",
                "Identify incorrect prime factorisations"
            ]
        },
        {
            "period": 2,
            "title": "HCF and LCM – Application Level",
            "topics_covered": [
                "HCF using prime factorisation",
                "LCM using prime factorisation",
                "Relation: HCF × LCM = product of two numbers"
            ],
            "teaching_strategy": [
                "Comparison table for HCF and LCM",
                "Guided problem-solving with reasoning"
            ],
            "student_activities": [
                "Find HCF and LCM of 24 and 90",
                "Verify HCF × LCM = product"
            ],
            "assessment": [
                "Board problems",
                "Peer-checked worksheet"
            ]
        },
        {
            "period": 3,
            "title": "HCF and LCM – Word Problems",
            "topics_covered": [
                "Real-life applications of HCF",
                "Real-life applications of LCM",
                "Identification of correct method"
            ],
            "teaching_strategy": [
                "Keyword-based approach (together, repeat, maximum, minimum)",
                "Step-by-step problem solving"
            ],
            "student_activities": [
                "Solve event and bell ringing problems",
                "Decide whether to apply HCF or LCM"
            ],
            "assessment": [
                "Case-based questions",
                "Short answer test"
            ]
        },
        {
            "period": 4,
            "title": "Euclid’s Division Algorithm",
            "topics_covered": [
                "Statement of Euclid’s Division Algorithm",
                "Finding HCF using Euclid’s method",
                "Comparison with prime factorisation method"
            ],
            "teaching_strategy": [
                "Explanation of division steps",
                "Complete worked example on board"
            ],
            "student_activities": [
                "Find HCF of 135 and 225 using Euclid’s Algorithm",
                "Practice two similar problems"
            ],
            "assessment": [
                "Individual written work",
                "Error-spotting questions"
            ]
        },
        {
            "period": 5,
            "title": "Irrational Numbers – Proof Understanding",
            "topics_covered": [
                "Rational and irrational numbers",
                "Proof of irrationality of √2",
                "Use of prime factorisation in proofs"
            ],
            "teaching_strategy": [
                "Logical step-by-step explanation of proof",
                "Highlighting contradiction clearly"
            ],
            "student_activities": [
                "Arrange proof steps in correct order",
                "Attempt guided proof of √3"
            ],
            "assessment": [
                "Assertion–Reason questions",
                "Short proof-based questions"
            ]
        },
        {
            "period": 6,
            "title": "Decimal Expansion of Rational Numbers",
            "topics_covered": [
                "Terminating decimal expansion",
                "Non-terminating repeating decimal expansion",
                "Rule based on prime factors of denominator"
            ],
            "teaching_strategy": [
                "Denominator factorisation approach",
                "Avoiding long division"
            ],
            "student_activities": [
                "Predict decimal nature of 13/20, 7/12, 9/25, and 11/30",
                "Justify answers using rules"
            ],
            "assessment": [
                "MCQs",
                "Reason-based questions"
            ]
        },
        {
            "period": 7,
            "title": "Integrated Revision and Assessment",
            "topics_covered": [
                "Complete chapter revision",
                "Mixed problems from all concepts"
            ],
            "teaching_strategy": [
                "Concept linking",
                "Student-led problem solving"
            ],
            "student_activities": [
                "Solve mixed worksheet",
                "Participate in group discussion"
            ],
            "assessment": [
                "Medium-level chapter test (15–20 marks)",
                "Doubt clarification session"
            ]
        }
    ],
    "teaching_aids": [
        "Blackboard or Whiteboard",
        "NCERT Mathematics Textbook",
        "Worksheets",
        "Flowcharts and comparison tables"
    ],
    "common_student_difficulties": [
        "Confusing lowest and highest powers in HCF and LCM",
        "Missing steps in irrationality proofs",
        "Choosing wrong method between HCF and LCM",
        "Not reducing fractions to lowest form"
    ],
    "teacher_tip": "Emphasise why each method works, not just how to apply it. Conceptual clarity improves exam performance."
