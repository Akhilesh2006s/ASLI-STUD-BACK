{
  "class": "Class 10",
  "subject": "Social Science (Economics)",
  "chapter_name": "Sectors of the Indian Economy",
  "lesson_level": "Easy",
  "total_periods": 7,
  "period_duration_minutes": "40-45",
  "overall_learning_objectives": [
    "Understand the three sectors of the economy",
    "Differentiate between primary, secondary and tertiary sectors",
    "Identify organised and unorganised sectors",
    "Understand public and private sectors",
    "Learn about employment and GDP contribution",
    "Recognise problems like disguised unemployment"
  ],
  "lesson_plan": [
    {
      "period": 1,
      "title": "Introduction to Sectors of the Economy",
      "topics_covered": [
        "Meaning of economic activities",
        "Classification into primary, secondary and tertiary sectors"
      ],
      "teaching_strategy": [
        "Simple explanation with examples",
        "Board classification table"
      ],
      "student_activities": [
        "Classify activities (farming, teaching, manufacturing)",
        "List examples of each sector"
      ],
      "assessment": ["Oral questioning", "Fill in the blanks"]
    },
    {
      "period": 2,
      "title": "Primary Sector",
      "topics_covered": [
        "Meaning of primary sector",
        "Examples: agriculture, fishing, mining",
        "Importance in India"
      ],
      "teaching_strategy": [
        "Discussion on local farming activities",
        "Picture-based explanation"
      ],
      "student_activities": [
        "Identify primary sector activities in your area",
        "Short note on agriculture"
      ],
      "assessment": ["Short answer questions", "Notebook checking"]
    },
    {
      "period": 3,
      "title": "Secondary Sector",
      "topics_covered": [
        "Meaning of secondary sector",
        "Manufacturing and industrial activities",
        "Conversion of raw materials"
      ],
      "teaching_strategy": [
        "Example-based explanation (cotton to cloth)",
        "Flowchart drawing"
      ],
      "student_activities": [
        "Draw process from raw material to finished product",
        "Give examples of industries"
      ],
      "assessment": ["Diagram-based question", "Oral test"]
    },
    {
      "period": 4,
      "title": "Tertiary Sector (Service Sector)",
      "topics_covered": [
        "Meaning of tertiary sector",
        "Examples: banking, transport, education",
        "Growth of service sector"
      ],
      "teaching_strategy": [
        "Discussion on services used daily",
        "Comparison chart"
      ],
      "student_activities": [
        "List services used in one day",
        "Classify services into tertiary sector"
      ],
      "assessment": ["MCQs", "Short answer questions"]
    },
    {
      "period": 5,
      "title": "Organised and Unorganised Sectors",
      "topics_covered": [
        "Meaning of organised sector",
        "Meaning of unorganised sector",
        "Job security and benefits"
      ],
      "teaching_strategy": ["Comparison table", "Real-life examples"],
      "student_activities": [
        "Compare government job vs street vendor",
        "List features of each sector"
      ],
      "assessment": ["True/False questions", "Class discussion"]
    },
    {
      "period": 6,
      "title": "Public and Private Sectors",
      "topics_covered": [
        "Meaning of public sector",
        "Meaning of private sector",
        "Role of government"
      ],
      "teaching_strategy": [
        "Examples (Indian Railways vs Private Company)",
        "Simple explanation"
      ],
      "student_activities": [
        "Identify public and private institutions in your area",
        "Short note on role of government"
      ],
      "assessment": ["Short written answers", "Oral questioning"]
    },
    {
      "period": 7,
      "title": "Employment and Chapter Revision",
      "topics_covered": [
        "Disguised unemployment",
        "Contribution to GDP",
        "Revision of all sectors"
      ],
      "teaching_strategy": [
        "Simple explanation with example",
        "Quick revision quiz"
      ],
      "student_activities": [
        "Explain disguised unemployment with example",
        "Participate in group quiz"
      ],
      "assessment": ["Short test (10 marks)", "Doubt clarification session"]
    }
  ],
  "teaching_aids": [
    "Blackboard or Whiteboard",
    "NCERT Economics Textbook",
    "Charts showing sector classification",
    "Pictures of economic activities"
  ],
  "evaluation_methods": [
    "Oral questioning",
    "MCQs",
    "Notebook checking",
    "Short answer tests",
    "Group quiz"
  ],
  "teacher_tip": "Use local and daily-life examples to explain sectors clearly. Students understand better when they relate concepts to real-world activities."
}
