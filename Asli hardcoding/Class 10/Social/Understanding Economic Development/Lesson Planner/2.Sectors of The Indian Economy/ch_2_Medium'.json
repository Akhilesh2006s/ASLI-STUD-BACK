{
  "class": "Class 10",
  "subject": "Social Science (Economics)",
  "chapter_name": "Sectors of the Indian Economy",
  "lesson_level": "Medium",
  "total_periods": 7,
  "period_duration_minutes": "40-45",
  "overall_learning_objectives": [
    "Differentiate clearly between primary, secondary and tertiary sectors",
    "Analyse contribution of sectors to GDP and employment",
    "Understand disguised unemployment with examples",
    "Compare organised and unorganised sectors",
    "Examine public and private sector roles",
    "Interpret simple data related to sector growth"
  ],
  "lesson_plan": [
    {
      "period": 1,
      "title": "Classification of Economic Activities",
      "topics_covered": [
        "Meaning of economic activities",
        "Primary, Secondary and Tertiary sectors",
        "Interdependence among sectors"
      ],
      "teaching_strategy": [
        "Flowchart explanation",
        "Real-life production chain example (wheat to bread)"
      ],
      "student_activities": [
        "Create a flowchart linking all three sectors",
        "Classify 10 activities into proper sectors"
      ],
      "assessment": ["Worksheet activity", "Oral questioning"]
    },
    {
      "period": 2,
      "title": "Primary Sector and Employment",
      "topics_covered": [
        "Role of agriculture in India",
        "Disguised unemployment",
        "Seasonal unemployment"
      ],
      "teaching_strategy": [
        "Case example of village farming",
        "Diagram explanation"
      ],
      "student_activities": [
        "Explain disguised unemployment with example",
        "Short paragraph on agricultural dependence"
      ],
      "assessment": ["Short answer questions", "Peer discussion"]
    },
    {
      "period": 3,
      "title": "Secondary Sector and Industrial Growth",
      "topics_covered": [
        "Manufacturing process",
        "Industrial development",
        "Importance of secondary sector"
      ],
      "teaching_strategy": [
        "Example-based explanation (cotton to cloth)",
        "Board comparison"
      ],
      "student_activities": [
        "Draw production chain diagram",
        "List benefits of industrialisation"
      ],
      "assessment": ["Diagram-based evaluation", "Notebook checking"]
    },
    {
      "period": 4,
      "title": "Tertiary Sector and Its Growth",
      "topics_covered": [
        "Service sector activities",
        "Rapid growth in India",
        "Role in supporting other sectors"
      ],
      "teaching_strategy": [
        "Data-based explanation (GDP share table)",
        "Discussion on IT and banking"
      ],
      "student_activities": [
        "Interpret simple GDP data chart",
        "Identify services used in daily life"
      ],
      "assessment": ["Data interpretation questions", "MCQs"]
    },
    {
      "period": 5,
      "title": "Organised and Unorganised Sectors",
      "topics_covered": [
        "Characteristics of organised sector",
        "Features of unorganised sector",
        "Worker protection and benefits"
      ],
      "teaching_strategy": [
        "Comparison table",
        "Case example (factory worker vs daily wage labourer)"
      ],
      "student_activities": [
        "Prepare comparison chart",
        "Group discussion on job security"
      ],
      "assessment": ["Short written test", "True/False questions"]
    },
    {
      "period": 6,
      "title": "Public and Private Sectors",
      "topics_covered": [
        "Meaning of public sector",
        "Meaning of private sector",
        "Role of government in development"
      ],
      "teaching_strategy": [
        "Examples (Indian Railways vs Private Airlines)",
        "Discussion-based learning"
      ],
      "student_activities": [
        "List public and private institutions",
        "Explain importance of public sector"
      ],
      "assessment": ["Short paragraph writing", "Oral questioning"]
    },
    {
      "period": 7,
      "title": "Sector Contribution and Chapter Assessment",
      "topics_covered": [
        "GDP contribution by sectors",
        "Employment trends",
        "Integrated revision"
      ],
      "teaching_strategy": [
        "Graph interpretation activity",
        "Quick quiz revision"
      ],
      "student_activities": [
        "Interpret employment data graph",
        "Participate in group quiz"
      ],
      "assessment": ["Short test (15 marks)", "Doubt clarification"]
    }
  ],
  "teaching_aids": [
    "Blackboard or Whiteboard",
    "NCERT Economics Textbook",
    "Sector contribution charts",
    "GDP and employment data tables",
    "Flowcharts and diagrams"
  ],
  "evaluation_methods": [
    "Data interpretation exercises",
    "MCQs",
    "Short answer tests",
    "Diagram evaluation",
    "Peer discussion"
  ],
  "teacher_tip": "Use simple data tables and graphs to help students connect theory with real economic trends. Encourage comparison-based answers for better conceptual clarity."
