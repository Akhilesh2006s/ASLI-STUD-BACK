{
  "class": "Class 10",
  "subject": "Social Science (Economics)",
  "chapter_name": "Development",
  "lesson_level": "Medium",
  "total_periods": 7,
  "period_duration_minutes": "40-45",
  "overall_learning_objectives": [
    "Analyse different perspectives of development",
    "Compare income with other development indicators",
    "Calculate and interpret per capita income",
    "Understand and evaluate HDI components",
    "Examine regional differences in development",
    "Apply concept of sustainable development in real-life situations"
  ],
  "lesson_plan": [
    {
      "period": 1,
      "title": "Perspectives on Development",
      "topics_covered": [
        "Meaning of development",
        "Different developmental goals",
        "Conflicting goals"
      ],
      "teaching_strategy": [
        "Case study discussion (farmer vs industrialist)",
        "Think–Pair–Share",
        "Concept mapping"
      ],
      "student_activities": [
        "Analyse a short case and identify conflicting goals",
        "Prepare a small comparison table of different people's goals"
      ],
      "assessment": [
        "Short analytical questions",
        "Group presentation (3 minutes)"
      ]
    },
    {
      "period": 2,
      "title": "Income and Non-Material Goals",
      "topics_covered": [
        "Role of income",
        "Limitations of income as measure",
        "Non-material goals (security, dignity, equality)"
      ],
      "teaching_strategy": [
        "Guided discussion",
        "Real-life examples",
        "Board comparison chart"
      ],
      "student_activities": [
        "Classify goals into material and non-material",
        "Write a short paragraph on 'Is money enough for development?'"
      ],
      "assessment": ["Notebook activity review", "Exit slip question"]
    },
    {
      "period": 3,
      "title": "Per Capita Income and Comparison of Countries",
      "topics_covered": [
        "National income",
        "Per capita income formula",
        "Comparison between countries"
      ],
      "teaching_strategy": [
        "Numerical problem solving",
        "Data interpretation using simple tables"
      ],
      "student_activities": [
        "Calculate per capita income from given data",
        "Compare two imaginary countries and justify which is more developed"
      ],
      "assessment": ["Short numerical test", "Peer correction"]
    },
    {
      "period": 4,
      "title": "Human Development Index (HDI)",
      "topics_covered": [
        "Meaning of HDI",
        "Health, Education, Income indicators",
        "Why HDI is better than income alone"
      ],
      "teaching_strategy": [
        "Flowchart explanation",
        "Data-based comparison (India vs Sri Lanka example)"
      ],
      "student_activities": [
        "Identify which indicators belong to health or education",
        "Interpret a simple HDI ranking table"
      ],
      "assessment": ["MCQs", "Data interpretation question"]
    },
    {
      "period": 5,
      "title": "Public Facilities and Regional Development",
      "topics_covered": [
        "Importance of public facilities",
        "Examples (healthcare, education, transport)",
        "Inter-state comparison"
      ],
      "teaching_strategy": ["Local area discussion", "State comparison chart"],
      "student_activities": [
        "List public facilities in your area",
        "Compare two states based on literacy or IMR"
      ],
      "assessment": ["Short written explanation", "Oral questioning"]
    },
    {
      "period": 6,
      "title": "Sustainable Development and Resource Use",
      "topics_covered": [
        "Meaning of sustainable development",
        "Renewable and non-renewable resources",
        "Environmental degradation"
      ],
      "teaching_strategy": [
        "Diagram explanation",
        "Problem-based learning (overuse of groundwater case)"
      ],
      "student_activities": [
        "Identify renewable and non-renewable resources",
        "Suggest measures to conserve resources"
      ],
      "assessment": ["Short answer questions", "Group discussion summary"]
    },
    {
      "period": 7,
      "title": "Application and Chapter Assessment",
      "topics_covered": [
        "Integrated revision",
        "Case-based questions",
        "Comparison-based questions"
      ],
      "teaching_strategy": [
        "Quiz competition",
        "Case study discussion",
        "Concept recap chart"
      ],
      "student_activities": [
        "Solve 5 mixed questions",
        "Create a mini concept map of the chapter"
      ],
      "assessment": [
        "Short test (15 marks)",
        "Doubt clarification and feedback"
      ]
    }
  ],
  "teaching_aids": [
    "Blackboard or Whiteboard",
    "NCERT Economics Textbook",
    "Charts showing HDI components",
    "Data tables for comparison",
    "Concept flowcharts"
  ],
  "evaluation_methods": [
    "Oral questioning",
    "Numerical exercises",
    "Data interpretation tasks",
    "Short tests",
    "Peer assessment"
  ],
  "teacher_tip": "Encourage students to think beyond definitions. Use real data and case-based questions to develop analytical understanding of development concepts."
}
