{
  "class": "Class 10",
  "subject": "Social Science (Economics)",
  "chapter_name": "Globalisation and the Indian Economy",
  "lesson_level": "Medium",
  "total_periods": 7,
  "period_duration_minutes": "40-45",
  "overall_learning_objectives": [
    "Explain the process of globalisation with examples",
    "Analyse the role of MNCs in India",
    "Understand Foreign Direct Investment (FDI)",
    "Examine the impact of liberalisation policy (1991)",
    "Interpret simple trade and investment data",
    "Evaluate positive and negative impacts of globalisation"
  ],
  "lesson_plan": [
    {
      "period": 1,
      "title": "Understanding Globalisation",
      "topics_covered": [
        "Meaning of globalisation",
        "Integration of markets",
        "Role of technology and communication"
      ],
      "teaching_strategy": [
        "Flowchart explanation",
        "Real-life product analysis",
        "Think–Pair–Share"
      ],
      "student_activities": [
        "Trace origin of a branded product",
        "Explain how technology promotes globalisation"
      ],
      "assessment": ["Short analytical questions", "Class discussion summary"]
    },
    {
      "period": 2,
      "title": "Multinational Corporations (MNCs) and FDI",
      "topics_covered": [
        "Meaning of MNCs",
        "How MNCs control production",
        "Foreign Direct Investment"
      ],
      "teaching_strategy": [
        "Case study (Coca-Cola or Samsung in India)",
        "Diagram explanation"
      ],
      "student_activities": [
        "Draw FDI flow diagram",
        "List advantages of MNC investment"
      ],
      "assessment": ["Case-based short answers", "MCQs"]
    },
    {
      "period": 3,
      "title": "Foreign Trade and Trade Barriers",
      "topics_covered": [
        "Exports and imports",
        "Trade barriers (tariffs)",
        "Expansion of markets"
      ],
      "teaching_strategy": [
        "Data interpretation using simple trade table",
        "Comparison of pre and post liberalisation"
      ],
      "student_activities": [
        "Interpret simple export-import data",
        "Explain impact of reducing tariffs"
      ],
      "assessment": ["Data-based questions", "Short written answers"]
    },
    {
      "period": 4,
      "title": "Liberalisation Policy (1991)",
      "topics_covered": [
        "Removal of trade restrictions",
        "Opening Indian economy",
        "Impact on Indian industries"
      ],
      "teaching_strategy": [
        "Before-after comparison chart",
        "Guided discussion"
      ],
      "student_activities": [
        "Prepare comparison table (Pre vs Post 1991)",
        "Short note on impact on consumers"
      ],
      "assessment": ["True/False", "Paragraph writing"]
    },
    {
      "period": 5,
      "title": "Role of WTO",
      "topics_covered": [
        "Functions of WTO",
        "Trade rules",
        "Impact on developing countries"
      ],
      "teaching_strategy": [
        "Question-answer session",
        "Case-based explanation"
      ],
      "student_activities": [
        "List WTO functions",
        "Discuss benefits and challenges for India"
      ],
      "assessment": ["Short analytical responses", "Oral questioning"]
    },
    {
      "period": 6,
      "title": "Impact of Globalisation in India",
      "topics_covered": [
        "Impact on consumers",
        "Impact on small producers",
        "Employment opportunities"
      ],
      "teaching_strategy": [
        "Case study (small scale industry)",
        "Group discussion"
      ],
      "student_activities": [
        "Analyse impact on small producers",
        "List advantages and disadvantages"
      ],
      "assessment": [
        "Application-based questions",
        "Group summary presentation"
      ]
    },
    {
      "period": 7,
      "title": "Data Interpretation and Chapter Assessment",
      "topics_covered": [
        "Trade growth data",
        "FDI inflow trends",
        "Integrated revision"
      ],
      "teaching_strategy": [
        "Graph interpretation activity",
        "Quiz-based revision"
      ],
      "student_activities": [
        "Interpret FDI graph",
        "Solve mixed case-based questions"
      ],
      "assessment": ["Short test (15 marks)", "Doubt clarification session"]
    }
  ],
  "teaching_aids": [
    "Blackboard or Whiteboard",
    "NCERT Economics Textbook",
    "World trade maps",
    "FDI and trade data charts",
    "Flowcharts"
  ],
  "evaluation_methods": [
    "Case-based questions",
    "Data interpretation worksheets",
    "MCQs",
    "Short analytical responses",
    "Group discussion"
  ],
  "teacher_tip": "Encourage students to connect globalisation concepts with real products and current economic examples to build analytical understanding."
}
