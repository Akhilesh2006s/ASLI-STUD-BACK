{
  "class": "Class 10",
  "subject": "Social Science (Economics)",
  "chapter_name": "Consumer Rights",
  "lesson_level": "Medium",
  "total_periods": 7,
  "period_duration_minutes": "40-45",
  "overall_learning_objectives": [
    "Explain different consumer rights with examples",
    "Analyse unfair trade practices using case studies",
    "Understand structure and functioning of consumer courts",
    "Differentiate between quality certification marks",
    "Apply steps for filing consumer complaints",
    "Develop awareness about consumer protection mechanisms"
  ],
  "lesson_plan": [
    {
      "period": 1,
      "title": "Consumer Exploitation and Need for Protection",
      "topics_covered": [
        "Meaning of consumer",
        "Types of consumer exploitation",
        "Need for Consumer Protection Act"
      ],
      "teaching_strategy": [
        "Case study discussion",
        "Brainstorming session",
        "Think–Pair–Share"
      ],
      "student_activities": [
        "Analyse real-life case of overcharging",
        "List reasons why consumers are exploited"
      ],
      "assessment": ["Short analytical responses", "Class discussion summary"]
    },
    {
      "period": 2,
      "title": "Detailed Study of Consumer Rights",
      "topics_covered": [
        "Right to Safety",
        "Right to Information",
        "Right to Choose",
        "Right to Seek Redressal",
        "Right to Consumer Education"
      ],
      "teaching_strategy": [
        "Matching activity (Right vs Example)",
        "Scenario-based explanation"
      ],
      "student_activities": [
        "Identify violated right in given situations",
        "Prepare summary chart of rights"
      ],
      "assessment": ["MCQs", "Case-based short answers"]
    },
    {
      "period": 3,
      "title": "Unfair Trade Practices and Misleading Advertisements",
      "topics_covered": ["False claims", "Underweight goods", "Adulteration"],
      "teaching_strategy": [
        "Advertisement analysis activity",
        "Group discussion"
      ],
      "student_activities": [
        "Identify misleading elements in advertisement",
        "Suggest how consumers can respond"
      ],
      "assessment": ["Short paragraph writing", "Peer evaluation"]
    },
    {
      "period": 4,
      "title": "Consumer Courts and Redressal Mechanism",
      "topics_covered": [
        "District Forum",
        "State Commission",
        "National Commission",
        "Filing procedure"
      ],
      "teaching_strategy": ["Flowchart explanation", "Case-based example"],
      "student_activities": [
        "Draw court hierarchy diagram",
        "Explain where to file a complaint in given case"
      ],
      "assessment": ["Diagram-based evaluation", "Application-based questions"]
    },
    {
      "period": 5,
      "title": "Quality Certification and Awareness",
      "topics_covered": [
        "ISI, Agmark, Hallmark",
        "Importance of bills and receipts",
        "Role of consumer organisations"
      ],
      "teaching_strategy": [
        "Display images of quality marks",
        "Comparison chart activity"
      ],
      "student_activities": [
        "Prepare comparison table of quality marks",
        "List precautions while purchasing goods"
      ],
      "assessment": ["Short answer questions", "Oral questioning"]
    },
    {
      "period": 6,
      "title": "Filing a Consumer Complaint – Practical Activity",
      "topics_covered": [
        "Steps to file complaint",
        "Required documents",
        "Importance of proof"
      ],
      "teaching_strategy": ["Role play activity", "Complaint letter drafting"],
      "student_activities": [
        "Draft complaint letter for defective product",
        "Participate in mock consumer court role play"
      ],
      "assessment": [
        "Written complaint evaluation",
        "Group participation marks"
      ]
    },
    {
      "period": 7,
      "title": "Integrated Case-Based Revision",
      "topics_covered": [
        "Application of consumer rights",
        "Court structure recap",
        "Awareness and responsibilities"
      ],
      "teaching_strategy": ["Case-based worksheet", "Quiz competition"],
      "student_activities": [
        "Solve 5 case-based questions",
        "Prepare mini concept map"
      ],
      "assessment": ["Short test (15 marks)", "Doubt clarification session"]
    }
  ],
  "teaching_aids": [
    "Blackboard or Whiteboard",
    "NCERT Economics Textbook",
    "Images of quality certification marks",
    "Consumer court flowchart",
    "Case study worksheets"
  ],
  "evaluation_methods": [
    "Case-based questions",
    "MCQs",
    "Diagram evaluation",
    "Complaint letter writing",
    "Group discussion"
  ],
  "teacher_tip": "Use real product labels and advertisements to make lessons interactive. Encourage students to think practically about their rights as consumers."
}
