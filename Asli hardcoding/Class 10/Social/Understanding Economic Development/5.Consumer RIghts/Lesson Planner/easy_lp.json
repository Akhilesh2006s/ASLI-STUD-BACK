{
  "class": "Class 10",
  "subject": "Social Science (Economics)",
  "chapter_name": "Consumer Rights",
  "lesson_level": "Easy",
  "total_periods": 7,
  "period_duration_minutes": "40-45",
  "overall_learning_objectives": [
    "Understand the meaning of consumer and consumer rights",
    "Identify different consumer rights",
    "Recognise unfair trade practices",
    "Understand the need for consumer protection",
    "Learn about consumer courts",
    "Develop awareness about quality marks"
  ],
  "lesson_plan": [
    {
      "period": 1,
      "title": "Introduction to Consumer and Consumer Rights",
      "topics_covered": [
        "Meaning of consumer",
        "Need for consumer protection",
        "Examples of consumer exploitation"
      ],
      "teaching_strategy": [
        "Story-based explanation",
        "Discussion on daily life examples"
      ],
      "student_activities": [
        "Share personal experiences of buying goods",
        "List common consumer problems"
      ],
      "assessment": ["Oral questioning", "Short written responses"]
    },
    {
      "period": 2,
      "title": "Consumer Rights – Overview",
      "topics_covered": [
        "Right to Safety",
        "Right to Information",
        "Right to Choose",
        "Right to Seek Redressal",
        "Right to Consumer Education"
      ],
      "teaching_strategy": ["Explanation with examples", "Chart presentation"],
      "student_activities": [
        "Match rights with examples",
        "Prepare small rights chart"
      ],
      "assessment": ["MCQs", "Fill in the blanks"]
    },
    {
      "period": 3,
      "title": "Unfair Trade Practices",
      "topics_covered": [
        "Meaning of unfair trade practice",
        "Misleading advertisements",
        "Underweight goods"
      ],
      "teaching_strategy": [
        "Case example discussion",
        "Picture-based explanation"
      ],
      "student_activities": [
        "Identify unfair practices from examples",
        "Short paragraph writing"
      ],
      "assessment": ["True/False questions", "Notebook checking"]
    },
    {
      "period": 4,
      "title": "Quality Marks and Consumer Awareness",
      "topics_covered": [
        "ISI mark",
        "Agmark",
        "Hallmark",
        "Importance of bills"
      ],
      "teaching_strategy": [
        "Display of quality mark images",
        "Simple explanation"
      ],
      "student_activities": [
        "List products with quality marks",
        "Explain why bill is important"
      ],
      "assessment": ["Short answer questions", "Oral questioning"]
    },
    {
      "period": 5,
      "title": "Consumer Protection Act and Consumer Courts",
      "topics_covered": [
        "Consumer Protection Act",
        "District Forum",
        "State Commission",
        "National Commission"
      ],
      "teaching_strategy": ["Flowchart explanation", "Question-answer session"],
      "student_activities": [
        "Draw hierarchy of consumer courts",
        "Explain where to file complaint"
      ],
      "assessment": ["Diagram-based evaluation", "MCQs"]
    },
    {
      "period": 6,
      "title": "Filing a Consumer Complaint",
      "topics_covered": [
        "Steps to file complaint",
        "Need for proof (bill/receipt)",
        "Role of consumer organisations"
      ],
      "teaching_strategy": [
        "Step-by-step explanation",
        "Simple role-play activity"
      ],
      "student_activities": [
        "Draft a simple complaint letter",
        "Participate in role play"
      ],
      "assessment": ["Short writing activity", "Peer review"]
    },
    {
      "period": 7,
      "title": "Chapter Revision and Assessment",
      "topics_covered": [
        "Revision of consumer rights",
        "Quality marks recap",
        "Consumer court structure"
      ],
      "teaching_strategy": ["Quiz-based revision", "Concept recap chart"],
      "student_activities": [
        "Participate in group quiz",
        "Prepare mini concept map"
      ],
      "assessment": ["Short test (10 marks)", "Doubt clarification session"]
    }
  ],
  "teaching_aids": [
    "Blackboard or Whiteboard",
    "NCERT Economics Textbook",
    "Images of quality marks (ISI, Agmark, Hallmark)",
    "Consumer court hierarchy chart"
  ],
  "evaluation_methods": [
    "Oral questioning",
    "MCQs",
    "Notebook checking",
    "Short answer tests",
    "Role-play participation"
  ],
  "teacher_tip": "Use real-life shopping examples and product labels to make consumer rights easy and relatable for students."
}
