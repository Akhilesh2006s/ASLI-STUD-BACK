{
  "class": "Class 10",
  "subject": "Social Science (Economics)",
  "chapter_name": "Money and Credit",
  "lesson_level": "Medium",
  "total_periods": 7,
  "period_duration_minutes": "40-45",
  "overall_learning_objectives": [
    "Explain the need for money in modern economy",
    "Analyse functions of money with real-life examples",
    "Understand terms of credit and their implications",
    "Differentiate between formal and informal credit sources",
    "Examine role of banks and RBI in regulating credit",
    "Evaluate problems like debt trap and financial exclusion"
  ],
  "lesson_plan": [
    {
      "period": 1,
      "title": "Barter System and Evolution of Money",
      "topics_covered": [
        "Barter system and its limitations",
        "Double coincidence of wants",
        "Evolution of money"
      ],
      "teaching_strategy": [
        "Role play activity",
        "Concept explanation using flowchart",
        "Class discussion"
      ],
      "student_activities": [
        "Demonstrate barter exchange in groups",
        "Explain why money is necessary"
      ],
      "assessment": [
        "Short analytical questions",
        "Exit slip (Explain double coincidence)"
      ]
    },
    {
      "period": 2,
      "title": "Functions and Modern Forms of Money",
      "topics_covered": [
        "Medium of exchange",
        "Unit of account",
        "Store of value",
        "Demand deposits and cheques"
      ],
      "teaching_strategy": [
        "Comparison chart (Barter vs Money)",
        "Cheque demonstration"
      ],
      "student_activities": [
        "Identify functions of money in daily life",
        "Explain how demand deposits work"
      ],
      "assessment": ["MCQs", "Short written responses"]
    },
    {
      "period": 3,
      "title": "Credit: Meaning and Terms",
      "topics_covered": [
        "Meaning of credit",
        "Interest rate",
        "Collateral",
        "Documentation and repayment"
      ],
      "teaching_strategy": [
        "Case study (Farmer vs Businessman loan case)",
        "Board explanation"
      ],
      "student_activities": [
        "Identify terms of credit from case",
        "Compare two loan conditions"
      ],
      "assessment": ["Case-based short answer", "Peer discussion"]
    },
    {
      "period": 4,
      "title": "Formal and Informal Credit",
      "topics_covered": [
        "Formal credit sources",
        "Informal credit sources",
        "Advantages and disadvantages"
      ],
      "teaching_strategy": ["Comparison table", "Real-life examples"],
      "student_activities": [
        "Prepare comparison chart",
        "Discuss risks of informal credit"
      ],
      "assessment": ["True/False", "Short paragraph writing"]
    },
    {
      "period": 5,
      "title": "Role of Banks and RBI",
      "topics_covered": [
        "Functions of commercial banks",
        "RBI as central bank",
        "Supervision of credit"
      ],
      "teaching_strategy": ["Flowchart explanation", "Question-answer session"],
      "student_activities": [
        "List functions of RBI",
        "Explain how banks create credit"
      ],
      "assessment": ["Short answer questions", "Oral questioning"]
    },
    {
      "period": 6,
      "title": "Debt Trap and Financial Inclusion",
      "topics_covered": [
        "Debt trap meaning",
        "Impact of high interest rates",
        "Importance of financial inclusion"
      ],
      "teaching_strategy": ["Story-based explanation", "Cause-effect diagram"],
      "student_activities": [
        "Analyse debt trap situation",
        "Suggest solutions to avoid debt trap"
      ],
      "assessment": ["Application-based questions", "Group discussion summary"]
    },
    {
      "period": 7,
      "title": "Data Interpretation and Chapter Revision",
      "topics_covered": [
        "Credit distribution data",
        "Formal vs informal sector share",
        "Integrated revision"
      ],
      "teaching_strategy": [
        "Graph interpretation activity",
        "Quiz-based revision"
      ],
      "student_activities": [
        "Interpret simple credit data table",
        "Participate in revision quiz"
      ],
      "assessment": ["Short test (15 marks)", "Doubt clarification session"]
    }
  ],
  "teaching_aids": [
    "Blackboard or Whiteboard",
    "NCERT Economics Textbook",
    "Sample cheque format",
    "Credit comparison charts",
    "Simple data tables"
  ],
  "evaluation_methods": [
    "Case-based questions",
    "MCQs",
    "Short answer tests",
    "Data interpretation tasks",
    "Peer discussion"
  ],
  "teacher_tip": "Use simple real-life credit examples (home loan, farmer loan, shopkeeper loan) to help students understand abstract financial terms clearly."
}
