{
    "class": "Class 10",
    "subject": "Science (CBSE)",
    "chapter": "Electricity",
    "difficulty": "Easy",
    "source_pdf": "ncert_class10_science_ch12.pdf",
    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Simple Electric Circuit Assembly",
            "objective": "Understand basic components of an electric circuit",
            "materials": [
                "Battery (dry cell)",
                "Connecting wires",
                "Switch (plug key)",
                "Torch bulb",
                "Cardboard base"
            ],
            "steps": [
                "Connect battery, switch, and bulb in series",
                "Close the switch and observe bulb glow",
                "Open switch and note what happens",
                "Draw circuit diagram"
            ],
            "learning_outcome": "Learns open/closed circuit and role of components",
            "evaluation": "Correct assembly and diagram (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Conductors vs Insulators Test",
            "objective": "Identify good and poor conductors",
            "materials": [
                "Battery",
                "Bulb",
                "Wires",
                "Various objects (metal spoon, plastic ruler, wood, rubber, coin, paper)"
            ],
            "steps": [
                "Set up simple circuit with gap",
                "Place each object in gap",
                "Check if bulb glows",
                "Categorize as conductor or insulator"
            ],
            "learning_outcome": "Distinguishes conductors and insulators",
            "evaluation": "List accuracy and explanation (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Ohm's Law Verification",
            "objective": "Verify Ohm's law using resistor and ammeter/voltmeter",
            "materials": [
                "Resistor (fixed, e.g., 10 Ω)",
                "Battery pack (variable voltage if possible)",
                "Ammeter, Voltmeter",
                "Connecting wires"
            ],
            "steps": [
                "Connect circuit with resistor, ammeter in series, voltmeter parallel",
                "Vary voltage (use different cells or rheostat)",
                "Record V and I for 5 readings",
                "Plot V vs I graph"
            ],
            "learning_outcome": "Understands linear relationship V = IR",
            "evaluation": "Graph and conclusion (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Factors Affecting Resistance - Length",
            "objective": "Show resistance depends on length of wire",
            "materials": [
                "Nichrome wire (long piece)",
                "Battery",
                "Ammeter",
                "Ruler",
                "Clips"
            ],
            "steps": [
                "Connect different lengths of same wire",
                "Measure current for each length",
                "Note inverse relation (longer wire, less current)",
                "Tabulate and explain"
            ],
            "learning_outcome": "Learns R ∝ l",
            "evaluation": "Observations and inference (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Series and Parallel Resistors Comparison",
            "objective": "Compare effective resistance in series and parallel",
            "materials": [
                "Two identical resistors (e.g., 10 Ω each)",
                "Battery",
                "Ammeter",
                "Switch"
            ],
            "steps": [
                "Connect in series, measure total current",
                "Connect in parallel, measure total current",
                "Compare with single resistor",
                "Calculate effective R"
            ],
            "learning_outcome": "Understands Rs = R1 + R2, 1/Rp = 1/R1 + 1/R2",
            "evaluation": "Calculations and comparison (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Heating Effect Demonstration",
            "objective": "Observe heating effect of current",
            "materials": [
                "Thin nichrome wire",
                "Battery",
                "Matches or paper strip"
            ],
            "steps": [
                "Pass current through nichrome wire",
                "Touch wire (carefully) or hold near paper to see heat",
                "Explain Joule's law"
            ],
            "learning_outcome": "Learns H = I²Rt and applications (heater, fuse)",
            "evaluation": "Observation and explanation (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Electric Power Calculation Poster",
            "objective": "Calculate power of household appliances",
            "materials": [
                "Chart paper",
                "Markers",
                "Labels of appliances (fan, bulb, TV)"
            ],
            "steps": [
                "Collect power ratings (e.g., 100 W bulb)",
                "Calculate energy for 1 hour (E = Pt)",
                "Draw poster with examples and units (kWh)"
            ],
            "learning_outcome": "Understands P = VI, P = I²R, electric bill basics",
            "evaluation": "Accuracy and presentation (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Domestic Wiring Model",
            "objective": "Understand household electric circuit",
            "materials": [
                "Cardboard house model",
                "Wires (red/black)",
                "Bulbs, switches",
                "Battery"
            ],
            "steps": [
                "Wire rooms in parallel with main switch",
                "Add fuse representation",
                "Explain live, neutral, earth wires",
                "Demonstrate short circuit risk"
            ],
            "learning_outcome": "Learns safety features in domestic circuits",
            "evaluation": "Model working and labels (10 marks)"
        },
        {
            "sl_no": 9,
            "title": "Fuse and Overload Simulation",
            "objective": "Show role of fuse in safety",
            "materials": [
                "Thin wire as fuse",
                "Bulb",
                "Extra load (add resistors or bulbs)"
            ],
            "steps": [
                "Connect thin wire in series",
                "Increase load to overload",
                "Observe wire heat/melt (simulate blow)",
                "Explain protection mechanism"
            ],
            "learning_outcome": "Understands fuse as safety device",
            "evaluation": "Demonstration and explanation (10 marks)"
        },
        {
            "sl_no": 10,
            "title": "Electricity in Daily Life Survey",
            "objective": "Identify electricity usage at home",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "List 10 appliances at home",
                "Note power rating and daily usage time",
                "Estimate total energy consumption",
                "Suggest ways to save electricity"
            ],
            "learning_outcome": "Connects chapter to real-life energy conservation",
            "evaluation": "Survey completeness and suggestions (10 marks)"
        }
    ]
}