    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Ohm's Law Graph with Variable Resistor",
            "objective": "Plot V-I graph and find resistance",
            "materials": [
                "Rheostat",
                "Battery",
                "Ammeter (0-5A)",
                "Voltmeter (0-5V)",
                "Graph paper"
            ],
            "steps": [
                "Vary resistance using rheostat",
                "Record 8-10 V and I pairs",
                "Plot V vs I, find slope = R",
                "Compare with color code value"
            ],
            "learning_outcome": "Verifies Ohm's law and measures R graphically",
            "evaluation": "Graph accuracy and R value (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Resistance vs Area of Cross-Section",
            "objective": "Study effect of thickness on resistance",
            "materials": [
                "Wires of same material/length but different thickness",
                "Battery",
                "Ammeter"
            ],
            "steps": [
                "Measure current for each wire",
                "Note inverse relation with area",
                "Tabulate and calculate relative R",
                "Explain R ∝ 1/A"
            ],
            "learning_outcome": "Understands factors affecting resistance",
            "evaluation": "Data table and inference (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Series-Parallel Combination Calculations",
            "objective": "Calculate equivalent resistance",
            "materials": [
                "Three resistors (different values)",
                "Battery",
                "Ammeter/Voltmeter"
            ],
            "steps": [
                "Connect in series, measure total R",
                "Connect in parallel, measure total R",
                "Mix series-parallel",
                "Verify with formula"
            ],
            "learning_outcome": "Masters equivalent resistance calculations",
            "evaluation": "Calculations and experimental match (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Joule's Heating Law Experiment",
            "objective": "Verify heat produced proportional to I²",
            "materials": [
                "Immersion heater coil",
                "Beaker with water",
                "Thermometer",
                "Ammeter",
                "Stopwatch"
            ],
            "steps": [
                "Pass different currents for fixed time",
                "Measure temperature rise",
                "Plot ΔT vs I²",
                "Conclude H ∝ I²"
            ],
            "learning_outcome": "Understands Joule's law quantitatively",
            "evaluation": "Graph and conclusion (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Electric Power and Energy Consumption",
            "objective": "Calculate monthly electricity bill",
            "materials": [
                "Notebook",
                "Calculator",
                "Appliance labels"
            ],
            "steps": [
                "List home appliances with wattage",
                "Estimate daily usage hours",
                "Calculate kWh/month",
                "Assume tariff and find bill cost"
            ],
            "learning_outcome": "Applies P = VI and energy units",
            "evaluation": "Calculations and realism (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Resistivity Measurement",
            "objective": "Find resistivity of material",
            "materials": [
                "Copper/nichrome wire",
                "Meter scale",
                "Micrometer (or known diameter)",
                "Circuit setup"
            ],
            "steps": [
                "Measure length, area, resistance",
                "Calculate ρ = R × A / l",
                "Compare with standard value"
            ],
            "learning_outcome": "Learns resistivity concept",
            "evaluation": "Calculation accuracy (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Short Circuit and Fuse Protection Model",
            "objective": "Demonstrate dangers and protection",
            "materials": [
                "Low resistance wire as fuse",
                "Battery",
                "Bulbs"
            ],
            "steps": [
                "Create overload/short by connecting low R",
                "Observe fuse melt",
                "Explain safety in real circuits"
            ],
            "learning_outcome": "Understands short circuit risks",
            "evaluation": "Demonstration and safety notes (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Earthing in Domestic Circuits Poster",
            "objective": "Illustrate importance of earthing",
            "materials": [
                "Chart paper",
                "Colors"
            ],
            "steps": [
                "Draw household wiring with earth wire",
                "Show fault current path to ground",
                "Explain shock prevention"
            ],
            "learning_outcome": "Learns safety via earthing",
            "evaluation": "Diagram clarity and explanation (10 marks)"
        },
        {
            "sl_no": 9,
            "title": "Numerical Problems Solving Session",
            "objective": "Solve chapter numericals",
            "materials": [
                "Notebook",
                "Calculator"
            ],
            "steps": [
                "Solve 8-10 problems (R eq, power, bill, heating)",
                "Include sign/units",
                "Present on chart"
            ],
            "learning_outcome": "Masters formula applications",
            "evaluation": "Correct solutions (10 marks)"
        },
        {
            "sl_no": 10,
            "title": "Battery Internal Resistance Model",
            "objective": "Estimate internal resistance",
            "materials": [
                "Old cell",
                "Resistors",
                "Voltmeter"
            ],
            "steps": [
