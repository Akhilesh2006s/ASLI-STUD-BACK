    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Graphical Determination of Resistance",
            "objective": "Find unknown resistance using V-I graph with error analysis",
            "materials": [
                "Unknown resistor",
                "Variable power supply",
                "Precise ammeter/voltmeter",
                "Graph paper"
            ],
            "steps": [
                "Take 10+ readings",
                "Plot V vs I, find best fit line",
                "Calculate R from slope, estimate % error"
            ],
            "learning_outcome": "Applies graphical method with precision",
            "evaluation": "Graph, R value, error discussion (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Temperature Dependence of Resistance",
            "objective": "Study resistance change with temperature",
            "materials": [
                "Thermistor or bulb filament",
                "Hot water bath",
                "Thermometer",
                "Circuit"
            ],
            "steps": [
                "Measure R at different temperatures",
                "Plot R vs T",
                "Explain positive coefficient"
            ],
            "learning_outcome": "Understands temperature effect on metals",
            "evaluation": "Graph and explanation (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Complex Circuit Analysis",
            "objective": "Solve Wheatstone bridge-like circuit",
            "materials": [
                "Four resistors (bridge setup)",
                "Galvanometer (or bulb)",
                "Battery"
            ],
            "steps": [
                "Set up unbalanced bridge",
                "Measure currents/voltages",
                "Calculate using Kirchhoff's laws",
                "Balance and verify"
            ],
            "learning_outcome": "Applies KCL/KVL",
            "evaluation": "Calculations and verification (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Heating Effect and Specific Heat",
            "objective": "Find specific heat using electrical method",
            "materials": [
                "Immersion heater",
                "Water in calorimeter",
                "Thermometer",
                "Ammeter, Voltmeter, Stopwatch"
            ],
            "steps": [
                "Heat water for time t",
                "Record ΔT, I, V",
                "Calculate heat = VIt = m s ΔT",
                "Find s (specific heat)"
            ],
            "learning_outcome": "Links Joule's law to calorimetry",
            "evaluation": "Calculation accuracy (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Maximum Power Transfer Theorem Demo",
            "objective": "Show load resistance = source resistance for max power",
            "materials": [
                "Battery with internal r",
                "Variable load resistor",
                "Voltmeter across load"
            ],
            "steps": [
                "Vary load R_L",
                "Measure power P = V²/R_L",
                "Find max P when R_L = r"
            ],
            "learning_outcome": "Understands power transfer optimization",
            "evaluation": "Graph and conclusion (10 marks)"
        },
