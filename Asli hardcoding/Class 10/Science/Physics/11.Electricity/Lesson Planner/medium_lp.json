{
    "class": "Class 10",
    "subject": "Science (CBSE)",
    "chapter_name": "Electricity",
    "lesson_level": "Medium",
    "total_periods": 6,
    "period_duration_minutes": "40-45",
    "overall_learning_objectives": [
        "Understand electric current, potential difference, and Ohm's law",
        "Apply Ohm's law to solve simple numerical problems",
        "Calculate resistance in series and parallel combinations",
        "Explain the heating effect and Joule's law qualitatively",
        "Calculate electric power and energy consumption",
        "Recognize factors affecting resistance and domestic wiring basics"
    ],
    "lesson_plan": [
        {
            "period": 1,
            "title": "Current, Voltage, and Ohm's Law",
            "topics_covered": [
                "Electric current, potential difference, resistance",
                "Ohm's law (V = IR)",
                "V-I graph for ohmic conductor"
            ],
            "teaching_strategy": [
                "Explain concepts with water analogy",
                "Draw V-I graph on board",
                "Solve 2-3 basic numericals"
            ],
            "student_activities": [
                "Solve simple Ohm's law problems (e.g., find I when V=12V, R=6Ω)",
                "Draw V-I graph from given data",
                "Explain why graph is straight line"
            ],
            "assessment": [
                "Numerical accuracy",
                "Graph and explanation"
            ]
        },
        {
            "period": 2,
            "title": "Factors Affecting Resistance",
            "topics_covered": [
                "Resistance depends on length, area, material, temperature",
                "Resistivity (ρ)",
                "Alloys like nichrome"
            ],
            "teaching_strategy": [
                "Show different wires demo (if possible)",
                "Explain formula R = ρl/A",
                "Discuss why nichrome used in heaters"
            ],
            "student_activities": [
                "Compare resistance of two wires (different length/thickness)",
                "Solve 2 numericals on resistivity",
                "Write why longer wire has more resistance"
            ],
            "assessment": [
                "Calculations",
                "Written explanation"
            ]
        },
        {
            "period": 3,
            "title": "Series and Parallel Combinations",
            "topics_covered": [
                "Series: Rs = R1 + R2 + ...",
                "Parallel: 1/Rp = 1/R1 + 1/R2 + ...",
                "Advantages of parallel wiring in homes"
            ],
            "teaching_strategy": [
                "Demonstrate with resistors or bulbs",
                "Solve step-by-step combination problems",
                "Draw equivalent circuits"
            ],
            "student_activities": [
                "Calculate equivalent resistance for 2-3 given combinations",
                "Draw series and parallel circuits",
                "Solve one NCERT exercise problem"
            ],
            "assessment": [
                "Correct calculations",
                "Circuit diagrams"
            ]
        },
        {
            "period": 4,
            "title": "Heating Effect and Joule's Law",
            "topics_covered": [
                "Heating effect of current",
                "Joule's law (H = I²Rt)",
                "Applications: heater, fuse, bulb"
            ],
            "teaching_strategy": [
                "Demo glowing wire/bulb",
                "Explain formula with examples",
                "Discuss fuse rating"
            ],
            "student_activities": [
                "Calculate heat produced in simple cases",
                "List 5 devices using heating effect",
                "Explain why fuse melts"
            ],
            "assessment": [
                "Calculations and list",
                "Explanation quality"
            ]
        },
        {
            "period": 5,
            "title": "Electric Power and Energy",
            "topics_covered": [
                "Power (P = VI = I²R = V²/R)",
                "Commercial unit: kWh",
                "Electric bill calculation"
            ],
            "teaching_strategy": [
                "Show sample electric bill",
                "Solve power and energy numericals",
                "Discuss energy saving tips"
            ],
            "student_activities": [
                "Calculate power and monthly energy for appliances",
                "Solve 3-4 NCERT-type numericals",
                "Suggest 5 ways to save electricity"
            ],
            "assessment": [
                "Numerical accuracy",
                "Suggestions"
            ]
        },
        {
            "period": 6,
            "title": "Revision, Numericals Practice & Applications",
            "topics_covered": [
                "Recap Ohm's law, combinations, power, heating",
                "Common board question types",
                "Domestic wiring and safety"
            ],
            "teaching_strategy": [
                "Quick recap with key formulas",
                "Mixed numerical quiz",
                "Discuss earthing, MCB, live/neutral"
            ],
            "student_activities": [
                "Solve 10-12 mixed problems",
                "Draw simple house wiring diagram",
                "Answer one application-based question"
            ],
            "assessment": [
                "Quiz performance",
                "Diagram and notebook"
            ]
        }
    ],
    "teaching_aids": [
        "NCERT textbook, circuit diagrams",
        "Resistors, battery, ammeter/voltmeter (demo)",
        "Chart of symbols and formulas",
        "Sample electric bill",
        "Whiteboard for numericals"
    ],
    "evaluation_methods": [
        "Numerical problem-solving",
        "Diagram accuracy",
        "Notebook checking",
        "Quiz and oral explanations"
    ],
    "teacher_tip": "Practice numericals daily – most board marks come from calculations and diagrams. Use real appliance examples to make concepts relatable. Emphasize units (V, A, Ω, W, kWh) to avoid common mistakes."
}