{
    "class": "Class 10",
    "subject": "Science (CBSE)",
    "chapter": "Electricity",
    "difficulty": "Easy",
    "source_pdf": "cbse_class10_science_ch11.pdf",
    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Household Appliances Power Survey",
            "objective": "Identify power ratings in daily life",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "List 10 electrical appliances at home (fan, bulb, TV, etc.)",
                "Note their power rating (watts) from labels",
                "Calculate monthly energy use assuming daily hours"
            ],
            "learning_outcome": "Understands electric power and energy consumption",
            "evaluation": "List completeness and basic calculations (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Simple Circuit Symbols Poster",
            "objective": "Learn circuit components",
            "materials": [
                "Chart paper",
                "Markers/colors"
            ],
            "steps": [
                "Draw and label 8-10 common symbols (battery, resistor, switch, ammeter, etc.)",
                "Explain each in 1-2 lines",
                "Display as poster"
            ],
            "learning_outcome": "Recognizes standard circuit symbols",
            "evaluation": "Accuracy and neatness (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Factors Affecting Resistance Demo",
            "objective": "Observe resistance changes",
            "materials": [
                "Different length/thickness wires (if available)",
                "Battery, bulb, switch"
            ],
            "steps": [
                "Connect wires of different lengths to a circuit with bulb",
                "Observe bulb brightness (longer wire = dimmer)",
                "Discuss why (resistance increases with length)"
            ],
            "learning_outcome": "Sees how length affects resistance",
            "evaluation": "Observation and simple explanation (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Series vs Parallel Bulb Circuit",
            "objective": "Compare circuit types",
            "materials": [
                "Batteries, bulbs, wires"
            ],
            "steps": [
                "Make series circuit with 2 bulbs",
                "Then parallel",
                "Observe what happens if one bulb is removed",
                "Note differences in brightness"
            ],
            "learning_outcome": "Understands series and parallel connections",
            "evaluation": "Demonstration and notes (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Ohm's Law Simple Verification",
            "objective": "Basic verification of V=IR",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "Draw a simple circuit diagram",
                "Assume values (V=10V, R=5Ω)",
                "Calculate I using Ohm's law",
                "Explain proportionality"
            ],
            "learning_outcome": "Applies Ohm's law basics",
            "evaluation": "Correct calculation and explanation (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Heating Effect Examples Collection",
            "objective": "See Joule's heating in daily use",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "List 5-7 devices using heating effect (iron, heater, toaster)",
                "Write how current produces heat",
                "Share one safety tip"
            ],
            "learning_outcome": "Connects heating effect to applications",
            "evaluation": "Examples and understanding (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Electricity Vocabulary Word Search",
            "objective": "Reinforce key terms",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "List 10 terms (current, voltage, resistance, ohm, watt, etc.)",
                "Create word search puzzle",
                "Exchange and solve with peers"
            ],
            "learning_outcome": "Builds terminology",
            "evaluation": "Puzzle design and solving (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Electric Bill Understanding",
            "objective": "Relate to real-life energy use",
            "materials": [
                "Sample bill or notebook"
            ],
            "steps": [
                "Look at a family electric bill (or imagine)",
                "Note units (kWh), cost per unit",
                "Calculate cost for one appliance"
            ],
            "learning_outcome": "Understands commercial electricity units",
            "evaluation": "Calculation and reflection (10 marks)"
        },
        {
            "sl_no": 9,
            "title": "Quick Quiz on Basic Concepts",
            "objective": "Test foundational knowledge",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "Prepare/answer 10 easy questions (definition of current, unit of power, etc.)",
                "Conduct in class or groups"
            ],
            "learning_outcome": "Reinforces basics interactively",
            "evaluation": "Participation and correctness (10 marks)"
        },
        {
            "sl_no": 10,
            "title": "Safety Rules for Electricity Poster",
            "objective": "Promote electrical safety",
            "materials": [
                "A4 paper",
                "Colors"
            ],
            "steps": [
                "List 6-8 safety tips (no wet hands, proper wiring)",
                "Illustrate with drawings",
                "Explain importance"
            ],
            "learning_outcome": "Develops awareness of electrical hazards",
            "evaluation": "Content and creativity (10 marks)"
        }
    ]
}