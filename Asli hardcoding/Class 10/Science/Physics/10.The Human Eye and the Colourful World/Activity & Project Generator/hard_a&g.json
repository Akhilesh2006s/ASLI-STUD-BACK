    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Quantitative Prism Experiment: Angle of Deviation vs Incidence",
            "objective": "Study relation between i and δ",
            "materials": [
                "Glass prism, protractor, pins, laser pointer"
            ],
            "steps": [
                "Vary angle of incidence (5-10 values)",
                "Measure angle of deviation each time",
                "Plot graph (i vs δ), find minimum deviation",
                "Calculate refractive index using formula"
            ],
            "learning_outcome": "Analyzes refraction quantitatively",
            "evaluation": "Data table, graph, calculation accuracy (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Advanced Ray Diagram Analysis for Presbyopia & Bifocals",
            "objective": "Explain complex vision defects",
            "materials": [
                "Graph paper, colored pencils"
            ],
            "steps": [
                "Draw detailed rays for presbyopic eye (near & far)",
                "Show bifocal lens correction (upper/lower parts)",
                "Calculate lens powers in dioptres for sample values",
                "Discuss age-related changes"
            ],
            "learning_outcome": "Handles multi-focal corrections mathematically",
            "evaluation": "Precision diagrams, calculations, discussion (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Scattering Intensity vs Wavelength Simulation",
            "objective": "Verify inverse fourth power law",
            "materials": [
                "Software/chart or simple LED filters (red/blue)",
                "Notebook for calculations"
            ],
            "steps": [
                "Use colored lights through scattering medium",
                "Observe/estimate intensity difference",
                "Calculate relative scattering (λ^4 relation)",
                "Explain blue dominance and red at horizon"
            ],
            "learning_outcome": "Applies mathematical dependence of scattering",
            "evaluation": "Calculations, observations, inference (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Extended Observation: Twinkling & Planetary Comparison",
            "objective": "Compare stars vs planets twinkling",
            "materials": [
                "Notebook, timer, clear night sky access"
            ],
            "steps": [
                "Observe 5 stars & 2 planets over 10-15 min",
                "Record fluctuation frequency/intensity",
                "Explain disk size vs point source effect",
                "Link to atmospheric turbulence"
            ],
            "learning_outcome": "Develops observational & analytical skills",
            "evaluation": "Data log, scientific reasoning (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Model of Human Eye with Adjustable Accommodation",
            "objective": "Simulate dynamic lens change",
            "materials": [
                "Bottle/balloon model, lenses, water (variable curvature)"
            ],
            "steps": [
                "Build model with changeable lens shape",
                "Demonstrate near/far focus adjustment",
                "Calculate approximate power change",
                "Compare to ciliary muscle action"
            ],
            "learning_outcome": "Models accommodation quantitatively",
            "evaluation": "Model working, calculations, explanation (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Prism Spectrum Wavelength Estimation",
            "objective": "Approximate wavelengths from dispersion",
            "materials": [
                "Prism setup, known light sources (e.g., sodium lamp if available)"
            ],
            "steps": [
                "Project spectrum, measure angular spread",
                "Use minimum deviation formula for estimation",
                "Compare to standard VIBGYOR wavelengths",
                "Discuss limitations"
            ],
            "learning_outcome": "Links experiment to quantitative optics",
            "evaluation": "Measurements, computations, analysis (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Case Study: Optical Phenomena in Pollution",
            "objective": "Analyze enhanced scattering effects",
            "materials": [
                "Reference articles, notebook"
            ],
            "steps": [
                "Research haze/fog impact on sky color/sunset",
                "Explain increased particle scattering",
                "Compare urban vs rural observations",
                "Propose simple experiment variation"
            ],
            "learning_outcome": "Applies concepts to environmental issues",
            "evaluation": "Research depth, analysis, creativity (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Debate & Presentation: Lens vs Contact vs Surgery",
            "objective": "Evaluate vision correction methods",
            "materials": [
                "Research notes, charts"
            ],
            "steps": [
                "Study pros/cons of spectacles, contacts, LASIK",
                "Relate to chapter defects (myopia range, risks)",
                "Present group debate with ray diagrams",
                "Conclude best for different cases"
            ],
            "learning_outcome": "Critical thinking on applications",
            "evaluation": "Content, diagrams, presentation (10 marks)"
        },
        {
            "sl_no": 9,
            "title": "Mathematical Modeling of Rainbow Angles",
            "objective": "Calculate rainbow geometry",
            "materials": [
                "Calculator, graph paper"
            ],
            "steps": [
                "Use refraction formula for raindrop",
                "Calculate deviation for primary/secondary rainbow",
                "Derive ~42° and ~51° angles",
                "Explain color separation order"
            ],
            "learning_outcome": "Uses Snell's law in real phenomena",
            "evaluation": "Derivations, accuracy, explanation (10 marks)"
        },
        {
            "sl_no": 10,
            "title": "Innovative Project: Homemade Spectrometer for Analysis",
            "objective": "Build & calibrate basic spectrometer",
            "materials": [
                "CD/DVD, cardboard box, slit, prism alternative"
            ],
            "steps": [
                "Construct diffraction grating spectrometer",
                "Calibrate with known sources (e.g., bulb, phone screen)",
                "Analyze everyday light sources' spectra",
                "Link to dispersion/scattering"
            ],
            "learning_outcome": "Advanced hands-on optics innovation",
            "evaluation": "Design, calibration, results analysis (10 marks)"
        }
    ]
