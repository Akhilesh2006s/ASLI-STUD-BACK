{
    "class": "Class 10",
    "subject": "Science (CBSE)",
    "chapter": "Heredity",
    "difficulty": "Easy",
    "source_pdf": "cbse_class10_science_ch8.pdf",
    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Earlobe Attachment Survey",
            "objective": "Observe a simple inherited trait in classmates",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "Check earlobes of 20-30 classmates (free or attached)",
                "Count and calculate percentage for each type",
                "Discuss which might be dominant"
            ],
            "learning_outcome": "Understands visible inherited traits",
            "evaluation": "Data accuracy and percentage calculation (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Tongue Rolling Check",
            "objective": "Identify a fun dominant trait",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "Ask classmates if they can roll their tongue",
                "Record yes/no and count percentages",
                "Relate to dominant/recessive traits"
            ],
            "learning_outcome": "Recognizes simple Mendelian traits",
            "evaluation": "Observation completeness and discussion (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Family Eye Color Collection",
            "objective": "See trait passing in families",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "Ask about eye color in own family (parents, siblings)",
                "List patterns observed",
                "Share in class"
            ],
            "learning_outcome": "Connects heredity to real life",
            "evaluation": "Examples and sharing quality (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Dominant vs Recessive Traits Chart",
            "objective": "List common human traits",
            "materials": [
                "Chart paper",
                "Markers"
            ],
            "steps": [
                "List 5-7 traits from textbook (e.g., dimples, curly hair)",
                "Mark dominant/recessive",
                "Display chart"
            ],
            "learning_outcome": "Learns basic trait classification",
            "evaluation": "Accuracy and neatness (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Simple Punnett Square Drawing",
            "objective": "Practice basic cross",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "Draw Punnett square for tall (TT) × short (tt)",
                "Show F1 all tall",
                "Explain dominance"
            ],
            "learning_outcome": "Understands monohybrid cross basics",
            "evaluation": "Correct square and explanation (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Chromosome Sex Determination Poster",
            "objective": "Visualize sex chromosomes",
            "materials": [
                "A4 paper",
                "Colors"
            ],
            "steps": [
                "Draw XX and XY chromosomes",
                "Show gametes and offspring possibilities",
                "Color code male/female"
            ],
            "learning_outcome": "Learns sex determination simply",
            "evaluation": "Diagram clarity (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Heredity Vocabulary Matching Game",
            "objective": "Reinforce key terms",
            "materials": [
                "Paper slips",
                "Pen"
            ],
            "steps": [
                "Write 8 terms (gene, allele, dominant, etc.) and definitions",
                "Match in pairs or groups",
                "Discuss wrong matches"
            ],
            "learning_outcome": "Builds basic terminology",
            "evaluation": "Matching accuracy (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Inherited Traits Self-Observation",
            "objective": "Personal connection to heredity",
            "materials": [
                "Notebook",
                "Mirror (optional)"
            ],
            "steps": [
                "List 4-5 own traits (hair, eye color, etc.)",
                "Note which come from mother/father",
                "Share one example"
            ],
            "learning_outcome": "Relates chapter to self",
            "evaluation": "Personal examples and reflection (10 marks)"
        },
        {
            "sl_no": 9,
            "title": "Quick Class Quiz on Traits",
            "objective": "Test basic concepts",
            "materials": [
                "Notebook",
                "Pen"
            ],
            "steps": [
                "Teacher or student asks 10 simple questions",
                "Answer individually or in teams",
                "Score and discuss"
            ],
            "learning_outcome": "Reinforces easy concepts",
            "evaluation": "Participation and correctness (10 marks)"
        },
        {
            "sl_no": 10,
            "title": "Why Variations Matter Drawing",
            "objective": "Understand variation importance",
            "materials": [
                "Paper",
                "Colors"
            ],
            "steps": [
                "Draw animals/plants in environment",
                "Show how variation helps survival (e.g., color camouflage)",
                "Write 2-3 lines explanation"
            ],
            "learning_outcome": "Sees role of variation",
            "evaluation": "Creativity and simple explanation (10 marks)"
        }
    ]
}