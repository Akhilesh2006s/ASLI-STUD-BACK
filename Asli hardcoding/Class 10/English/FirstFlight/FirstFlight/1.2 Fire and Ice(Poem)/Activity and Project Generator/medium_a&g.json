            "sl_no": 1,
            "title": "Symbolism Analysis",
            "objective": "Analyse the symbols used in the poem",
            "materials": [
                "Textbook",
                "Notebook"
            ],
            "steps": [
                "Read the poem carefully",
                "Identify what fire and ice represent",
                "Write 3–4 sentences explaining the symbolism"
            ],
            "learning_outcome": "Understands symbolic meaning in poetry",
            "evaluation": "Accuracy of explanation (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Poet’s Belief Discussion",
            "objective": "Understand the poet’s viewpoint",
            "materials": [
                "Textbook",
                "Notebook"
            ],
            "steps": [
                "Read the poem again",
                "Identify which idea the poet seems to support",
                "Write 4 sentences explaining the poet’s belief"
            ],
            "learning_outcome": "Interprets poet’s opinion",
            "evaluation": "Clarity of interpretation (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Emotion Identification",
            "objective": "Identify emotions represented in the poem",
            "materials": [
                "Textbook",
                "Notebook"
