    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Quadrant Plotting Challenge",
            "objective": "Plot points in different quadrants",
            "materials": [
                "Graph paper",
                "Pencil",
                "Scale"
            ],
            "steps": [
                "Draw the coordinate axes",
                "Plot the points (3,4), (-3,4), (-4,-2), (2,-3)",
                "Write the quadrant of each point"
            ],
            "learning_outcome": "Understands quadrant positions of points",
            "evaluation": "Correct plotting and quadrant identification (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Coordinate Reading Practice",
            "objective": "Read coordinates from plotted graph",
            "materials": [
                "Graph paper"
            ],
            "steps": [
                "Plot five random points on graph paper",
                "Exchange the graph with a friend",
                "Write the coordinates of the friend's points"
            ],
            "learning_outcome": "Improves coordinate reading ability",
            "evaluation": "Accuracy of coordinates (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Axis Distance Observation",
            "objective": "Understand distance of points from axes",
            "materials": [
                "Graph paper"
            ],
            "steps": [
                "Plot the point (4,3)",
                "Measure distance from x-axis and y-axis",
                "Record the distances"
            ],
            "learning_outcome": "Understands coordinate meaning as distances",
            "evaluation": "Correct measurement (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Sign Pattern Activity",
            "objective": "Study coordinate signs in quadrants",
            "materials": [
                "Notebook",
                "Graph paper"
            ],
            "steps": [
                "Draw the coordinate plane",
                "Write example coordinates for each quadrant",
                "Identify sign patterns (+,+), (-,+), (-,-), (+,-)"
            ],
            "learning_outcome": "Recognises sign conventions",
            "evaluation": "Correct examples (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Axis Point Investigation",
            "objective": "Understand coordinates of points on axes",
            "materials": [
                "Graph paper"
            ],
            "steps": [
                "Plot points (5,0), (-3,0), (0,6), (0,-2)",
                "Observe which axis they lie on",
                "Write a rule for coordinates on axes"
            ],
            "learning_outcome": "Understands coordinates on axes",
            "evaluation": "Correct observation and rule (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Create a Coordinate Table",
            "objective": "Record coordinates systematically",
            "materials": [
                "Graph paper",
                "Notebook"
            ],
            "steps": [
                "Plot points A(2,3), B(-2,4), C(-4,-1), D(3,-2)",
                "Create a table listing point name and coordinates",
                "Write the quadrant for each point"
            ],
            "learning_outcome": "Improves data representation skill",
            "evaluation": "Correct table entries (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Symmetry Activity",
            "objective": "Understand symmetry across axes",
            "materials": [
                "Graph paper"
            ],
            "steps": [
                "Plot point A(2,3)",
                "Plot its reflections across x-axis and y-axis",
                "Write coordinates of reflected points"
            ],
            "learning_outcome": "Understands coordinate symmetry",
            "evaluation": "Correct reflected coordinates (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Rectangle Formation",
            "objective": "Form shapes using coordinates",
            "materials": [
                "Graph paper",
                "Pencil"
            ],
            "steps": [
                "Plot points (1,2), (5,2), (5,5), (1,5)",
                "Join the points sequentially",
                "Identify the shape"
            ],
            "learning_outcome": "Applies plotting to geometric shapes",
            "evaluation": "Correct shape formation (10 marks)"
        },
        {
            "sl_no": 9,
            "title": "Origin Exploration",
            "objective": "Investigate the role of origin",
            "materials": [
                "Graph paper"
            ],
            "steps": [
                "Plot points around the origin",
                "Observe how coordinates change in different directions",
                "Write observations"
            ],
            "learning_outcome": "Understands reference point concept",
            "evaluation": "Clarity of observations (10 marks)"
        },
        {
            "sl_no": 10,
            "title": "Coordinate Game",
            "objective": "Practice plotting through a game",
            "materials": [
                "Graph paper"
            ],
            "steps": [
                "Teacher gives random coordinates",
                "Students plot them quickly",
                "Compare answers with classmates"
            ],
            "learning_outcome": "Improves speed and accuracy in plotting",
            "evaluation": "Correct plots (10 marks)"
        }
    ]
}