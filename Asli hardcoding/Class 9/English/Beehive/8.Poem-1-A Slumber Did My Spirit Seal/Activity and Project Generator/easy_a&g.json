{
    "class": "Class 9",
    "subject": "English",
    "chapter": "A Slumber Did My Spirit Seal",
    "author": "William Wordsworth",
    "difficulty": "Easy",
    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Poet Identification",
            "objective": "Identify the poet and poem",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Read the poem",
                "Write the name of the poet and the poem"
            ],
            "learning_outcome": "Identifies author and poem",
            "evaluation": "Correct answer (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Theme of the Poem",
            "objective": "Understand the central idea",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Read the poem carefully",
                "Write the main theme in 2–3 sentences"
            ],
            "learning_outcome": "Understands theme of the poem",
            "evaluation": "Relevant explanation (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Meaning of Slumber",
            "objective": "Learn vocabulary from the poem",
            "materials": [
                "Dictionary"
            ],
            "steps": [
                "Find the meaning of 'slumber'",
                "Write one sentence using the word"
            ],
            "learning_outcome": "Improves vocabulary",
            "evaluation": "Correct meaning and sentence (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Poet’s Feelings",
            "objective": "Understand the poet’s emotions",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Identify how the poet feels about the girl's death",
                "Write 3–4 lines explaining his feelings"
            ],
            "learning_outcome": "Recognises emotions in poetry",
            "evaluation": "Clarity of explanation (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Lines About Time",
            "objective": "Identify important lines",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Find the lines describing the passing of time",
                "Write them in your notebook"
            ],
            "learning_outcome": "Identifies poetic expressions",
            "evaluation": "Correct lines written (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Nature Imagery",
            "objective": "Recognise imagery in the poem",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Find the natural elements mentioned",
                "List them in points"
            ],
            "learning_outcome": "Understands imagery",
            "evaluation": "Correct examples (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Meaning of Diurnal",
            "objective": "Learn glossary words",
            "materials": [
                "Dictionary"
            ],
            "steps": [
                "Find the meaning of 'diurnal'",
                "Write the meaning in your notebook"
            ],
            "learning_outcome": "Builds vocabulary knowledge",
            "evaluation": "Correct meaning (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Favourite Line",
            "objective": "Encourage personal interpretation",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Choose your favourite line",
                "Write why you like it"
            ],
            "learning_outcome": "Develops appreciation of poetry",
            "evaluation": "Reason clearly written (10 marks)"
        }
    ]
}