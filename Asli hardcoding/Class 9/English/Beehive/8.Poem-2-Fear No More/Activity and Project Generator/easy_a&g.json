            "evaluation": "Correct examples (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Message of the Poem",
            "objective": "Understand the moral idea",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Think about the message of the poem",
                "Write 3–4 lines explaining it"
            ],
            "learning_outcome": "Understands life message",
            "evaluation": "Logical explanation (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Vocabulary from the Poem",
            "objective": "Improve vocabulary",
            "materials": [
