            "sl_no": 1,
            "title": "Poet and Poem",
            "objective": "Identify the poet",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Read the poem",
                "Write the poet's name and poem title"
            ],
            "learning_outcome": "Recognises the author",
            "evaluation": "Correct answer (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Theme of the Poem",
            "objective": "Understand the main idea",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Read the poem carefully",
                "Write the theme in 2–3 sentences"
            ],
            "learning_outcome": "Understands theme of the poem",
            "evaluation": "Clear explanation (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Meaning of Dust",
            "objective": "Understand symbolic meaning",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Find the meaning of 'come to dust'",
                "Write what it symbolises"
            ],
            "learning_outcome": "Understands poetic symbolism",
            "evaluation": "Correct explanation (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Things We Need Not Fear",
            "objective": "Identify key ideas",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "List the things people need not fear after death",
                "Write them in points"
            ],
            "learning_outcome": "Identifies main points in the poem",
            "evaluation": "Correct listing (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Natural Elements",
            "objective": "Recognise nature imagery",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Find natural elements mentioned",
                "Write them in your notebook"
            ],
