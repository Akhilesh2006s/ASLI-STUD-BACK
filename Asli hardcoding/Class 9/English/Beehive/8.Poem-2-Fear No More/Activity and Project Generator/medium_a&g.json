{
    "class": "Class 9",
    "subject": "English",
    "chapter": "Fear No More",
    "author": "William Shakespeare",
    "difficulty": "Medium",
    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Theme Identification",
            "objective": "Understand the central theme of the poem",
            "materials": [
                "Textbook",
                "Notebook"
            ],
            "steps": [
                "Read the poem carefully",
                "Write the theme in 4–5 sentences"
            ],
            "learning_outcome": "Understands theme of the poem",
            "evaluation": "Clear explanation (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Things People Need Not Fear",
            "objective": "Identify ideas expressed in the poem",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "List the things the poet says people need not fear",
                "Write them in points"
            ],
            "learning_outcome": "Recognises key ideas",
            "evaluation": "Correct listing (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Symbolism of Dust",
            "objective": "Understand symbolic meaning",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Find the line mentioning 'dust'",
                "Explain its symbolic meaning"
            ],
            "learning_outcome": "Understands symbolism",
            "evaluation": "Logical explanation (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Natural Elements",
            "objective": "Recognise imagery in the poem",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Find natural elements mentioned in the poem",
                "Write them with explanation"
            ],
            "learning_outcome": "Identifies imagery",
            "evaluation": "Correct examples (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Vocabulary Study",
            "objective": "Improve vocabulary skills",
            "materials": [
                "Dictionary"
            ],
            "steps": [
                "Choose three difficult words",
                "Write meanings and sentences"
            ],
            "learning_outcome": "Develops vocabulary",
            "evaluation": "Correct usage (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Message of the Poem",
            "objective": "Understand the poet’s message",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Think about what the poem says about life and death",
                "Write 5 lines explaining the message"
            ],
            "learning_outcome": "Understands philosophical idea",
            "evaluation": "Clear explanation (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Poem Structure",
            "objective": "Observe the structure of the poem",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Count the number of stanzas",
                "Write how the poem is organised"
            ],
            "learning_outcome": "Recognises poem structure",
            "evaluation": "Correct observation (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Poetic Devices",
            "objective": "Identify literary techniques",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Find one poetic device used in the poem",
                "Explain it briefly"
            ],
            "learning_outcome": "Recognises poetic devices",
            "evaluation": "Correct explanation (10 marks)"
        },
        {
            "sl_no": 9,
            "title": "Personal Reflection",
            "objective": "Encourage interpretation",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Write your opinion about the poem",
                "Explain why the message is important"
            ],
            "learning_outcome": "Develops reflective thinking",
            "evaluation": "Thoughtful explanation (10 marks)"
        },
        {
            "sl_no": 10,
            "title": "Recitation Activity",
            "objective": "Develop speaking skills",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Read the poem aloud",
                "Practice reciting it with expression"
            ],
            "learning_outcome": "Improves confidence and pronunciation",
            "evaluation": "Clear recitation (10 marks)"
        }
    ]
}