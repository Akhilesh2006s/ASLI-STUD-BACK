{
    "class": "Class 9",
    "subject": "English",
    "chapter": "A Slumber Did My Spirit Seal",
    "author": "William Wordsworth",
    "difficulty": "Medium",
    "activities_projects": [
        {
            "sl_no": 1,
            "title": "Theme Identification",
            "objective": "Understand the central idea of the poem",
            "materials": [
                "Textbook",
                "Notebook"
            ],
            "steps": [
                "Read the poem carefully",
                "Write the main theme of the poem in 4–5 sentences"
            ],
            "learning_outcome": "Understands the theme of the poem",
            "evaluation": "Clear explanation of theme (10 marks)"
        },
        {
            "sl_no": 2,
            "title": "Poet’s Reaction to Death",
            "objective": "Analyse the poet’s feelings about the girl’s death",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Read the poem again",
                "Write 4–5 lines describing the poet’s reaction"
            ],
            "learning_outcome": "Understands emotional tone of the poem",
            "evaluation": "Relevant explanation (10 marks)"
        },
        {
            "sl_no": 3,
            "title": "Lines Showing Timelessness",
            "objective": "Identify lines related to time",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Find lines that show time no longer affects the girl",
                "Write them in your notebook"
            ],
            "learning_outcome": "Identifies key poetic lines",
            "evaluation": "Correct lines written (10 marks)"
        },
        {
            "sl_no": 4,
            "title": "Nature Imagery",
            "objective": "Recognise natural elements used in the poem",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Find nature elements mentioned in the poem",
                "List them with explanation"
            ],
            "learning_outcome": "Understands imagery in poetry",
            "evaluation": "Correct identification (10 marks)"
        },
        {
            "sl_no": 5,
            "title": "Meaning of Important Words",
            "objective": "Improve vocabulary",
            "materials": [
                "Dictionary"
            ],
            "steps": [
                "Find meanings of 'slumber', 'diurnal', and 'force'",
                "Write sentences using them"
            ],
            "learning_outcome": "Builds vocabulary skills",
            "evaluation": "Correct meanings and usage (10 marks)"
        },
        {
            "sl_no": 6,
            "title": "Poetic Devices",
            "objective": "Identify literary techniques",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Find one poetic device in the poem",
                "Explain how it is used"
            ],
            "learning_outcome": "Recognises poetic devices",
            "evaluation": "Correct explanation (10 marks)"
        },
        {
            "sl_no": 7,
            "title": "Meaning of the Title",
            "objective": "Interpret the title of the poem",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Think about the title",
                "Write 4 lines explaining its meaning"
            ],
            "learning_outcome": "Understands title significance",
            "evaluation": "Logical interpretation (10 marks)"
        },
        {
            "sl_no": 8,
            "title": "Structure of the Poem",
            "objective": "Observe poem structure",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Count the number of stanzas",
                "Write how the poem is structured"
            ],
            "learning_outcome": "Recognises poem structure",
            "evaluation": "Correct observation (10 marks)"
        },
        {
            "sl_no": 9,
            "title": "Personal Interpretation",
            "objective": "Encourage critical thinking",
            "materials": [
                "Notebook"
            ],
            "steps": [
                "Write your understanding of the poem",
                "Explain why the poem is meaningful"
            ],
            "learning_outcome": "Develops interpretation skills",
            "evaluation": "Thoughtful explanation (10 marks)"
        },
        {
            "sl_no": 10,
            "title": "Recitation Practice",
            "objective": "Improve reading and speaking skills",
            "materials": [
                "Textbook"
            ],
            "steps": [
                "Practice reading the poem aloud",
                "Recite it with proper expression"
            ],
            "learning_outcome": "Improves pronunciation and confidence",
            "evaluation": "Clear recitation (10 marks)"
