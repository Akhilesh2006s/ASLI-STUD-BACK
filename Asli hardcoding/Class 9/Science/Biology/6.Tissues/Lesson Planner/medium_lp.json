                "Comparison between plant and animal tissues"
            ],
            "teaching_strategy": [
                "Interactive discussion",
                "Concept explanation using examples"
            ],
            "student_activities": [
                "Write definition of tissue",
                "Give examples of tissues in plants and animals"
            ],
            "assessment": [
                "Oral questioning",
                "Short written responses"
            ]
        },
        {
            "period": 2,
            "title": "Meristematic Tissue",
