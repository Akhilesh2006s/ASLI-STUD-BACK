            ],
            "student_activities": [
                "Identify weeds from pictures",
                "Discuss storage methods"
            ],
            "assessment": [
                "Short written questions",
                "Oral questioning"
            ]
        },
        {
            "period": 7,
            "title": "Animal Husbandry and Revision",
            "topics_covered": [
