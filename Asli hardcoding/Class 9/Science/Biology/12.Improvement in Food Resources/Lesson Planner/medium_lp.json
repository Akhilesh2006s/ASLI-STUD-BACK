                "Green revolution",
                "White revolution"
            ],
            "teaching_strategy": [
                "Discussion on food demand",
                "Board explanation",
                "Examples from daily life"
            ],
            "student_activities": [
                "List sources of food",
                "Discuss reasons for improving food production"
            ],
            "assessment": [
                "Oral questioning",
                "Short written answers"
            ]
        },
        {
            "period": 2,
            "title": "Types of Crops and Crop Seasons",
            "topics_covered": [
