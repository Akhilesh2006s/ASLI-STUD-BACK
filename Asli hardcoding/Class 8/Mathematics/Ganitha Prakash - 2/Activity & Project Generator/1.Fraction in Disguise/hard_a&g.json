{
  "class": "Class 8",
  "subject": "Mathematics",
  "chapter": "Fractions in Disguise (Percentages)",
  "difficulty": "Hard",
  "source_pdf": "hegp201.pdf",
  "activities_projects": [
    {
      "sl_no": 1,
      "title": "Mixed Percentage Calculation",
      "objective": "Solve multi-step percentage problems",
      "materials": ["Notebook"],
      "steps": [
        "Choose a number such as 500",
        "Find 25% of it",
        "Then find 40% of the result",
        "Compare with calculating 10% of the original number"
      ],
      "learning_outcome": "Develops multi-step problem solving",
      "evaluation": "Correct solutions (10 marks)"
    },
    {
      "sl_no": 2,
      "title": "Reverse Percentage Problem",
      "objective": "Find original values from percentages",
      "materials": ["Notebook"],
      "steps": [
        "Assume 30% of a number equals 120",
        "Find the original number",
        "Verify by multiplying with percentage"
      ],
      "learning_outcome": "Understands reverse percentage calculations",
      "evaluation": "Correct answer (10 marks)"
    },
    {
      "sl_no": 3,
      "title": "Compound Interest Exploration",
      "objective": "Understand compounding growth",
      "materials": ["Notebook", "Calculator"],
      "steps": [
        "Assume principal ₹2000",
        "Interest rate 10% per year",
        "Calculate amount after 3 years with compounding"
      ],
      "learning_outcome": "Understands compound growth concept",
      "evaluation": "Correct final amount (10 marks)"
    },
    {
      "sl_no": 4,
      "title": "Percentage Change Investigation",
      "objective": "Analyze percentage increase and decrease",
      "materials": ["Notebook"],
      "steps": [
        "Take original price ₹500",
        "Increase it by 20%",
        "Then decrease the new value by 20%",
        "Compare with original price"
      ],
      "learning_outcome": "Understands effects of repeated percentage changes",
      "evaluation": "Correct reasoning (10 marks)"
    },
    {
      "sl_no": 5,
      "title": "Profit and Loss Comparison",
      "objective": "Analyze multiple profit and loss cases",
      "materials": ["Notebook"],
      "steps": [
        "Assume cost price ₹800",
        "Case 1: Sell with 15% profit",
        "Case 2: Sell with 10% loss",
        "Compare final prices"
      ],
      "learning_outcome": "Understands profit and loss relationships",
      "evaluation": "Correct calculations (10 marks)"
    },
    {
      "sl_no": 6,
      "title": "Population Growth Model",
      "objective": "Model population growth using percentages",
      "materials": ["Notebook"],
      "steps": [
        "Assume population 5000",
        "Increase it by 5% each year for 3 years",
        "Calculate population after each year"
      ],
      "learning_outcome": "Understands repeated percentage growth",
      "evaluation": "Correct values (10 marks)"
    },
    {
      "sl_no": 7,
      "title": "Data Analysis with Percentages",
      "objective": "Interpret percentage data",
      "materials": ["Notebook"],
      "steps": [
        "Collect data of marks scored by five students",
        "Convert marks into percentages",
        "Rank students based on percentages"
      ],
      "learning_outcome": "Improves data interpretation skills",
      "evaluation": "Correct analysis (10 marks)"
    },
    {
      "sl_no": 8,
      "title": "Percentage Puzzle",
      "objective": "Solve complex percentage puzzles",
      "materials": ["Notebook"],
      "steps": [
        "Create a puzzle where one value is a percentage of another",
        "Give clues using percentage relationships",
        "Ask classmates to solve it"
      ],
      "learning_outcome": "Encourages logical thinking",
      "evaluation": "Clarity and solvability of puzzle (10 marks)"
    }
  ]
}
