  "activities_projects": [
    {
      "sl_no": 1,
      "title": "Perfect Square Investigation",
      "objective": "Explore patterns in perfect squares",
      "materials": ["Notebook", "Calculator"],
      "steps": [
        "List perfect squares from 1² to 20²",
        "Find the difference between consecutive squares",
        "Identify and explain the pattern"
      ],
      "learning_outcome": "Recognises patterns in square numbers",
      "evaluation": "Correct pattern explanation (10 marks)"
    },
    {
      "sl_no": 2,
      "title": "Square Root by Prime Factorisation",
      "objective": "Find square roots using prime factorisation",
      "materials": ["Notebook"],
      "steps": [
        "Choose five large perfect square numbers",
        "Write their prime factorisation",
        "Group factors in pairs to find square roots"
      ],
      "learning_outcome": "Applies prime factorisation to find square roots",
      "evaluation": "Correct factorisation and root (10 marks)"
    },
    {
      "sl_no": 3,
      "title": "Cube Root Challenge",
      "objective": "Find cube roots using factorisation",
      "materials": ["Notebook"],
      "steps": [
        "Write numbers such as 512, 729, 1000 and 1728",
        "Find their prime factorisation",
        "Group factors in triples to determine cube roots"
      ],
      "learning_outcome": "Understands cube root calculation",
      "evaluation": "Accuracy of cube roots (10 marks)"
    },
    {
      "sl_no": 4,
      "title": "Square Grid Area Problem",
      "objective": "Relate square numbers to area",
      "materials": ["Graph paper", "Pencil"],
      "steps": [
        "Draw squares of side lengths 2, 4, 6 and 8 units",
        "Calculate the area of each square",
        "Explain how the area relates to square numbers"
      ],
      "learning_outcome": "Applies square concept to geometry",
      "evaluation": "Correct calculations and explanation (10 marks)"
    },
    {
      "sl_no": 5,
      "title": "Large Cube Construction",
      "objective": "Understand volume through cubes",
      "materials": ["Small blocks or cubes", "Notebook"],
      "steps": [
        "Construct a 4×4×4 cube using blocks",
        "Count the total blocks used",
        "Explain how the number relates to cube numbers"
      ],
      "learning_outcome": "Visualises cubic numbers and volume",
      "evaluation": "Correct reasoning (10 marks)"
    },
    {
      "sl_no": 6,
      "title": "Nearest Perfect Square Finder",
      "objective": "Estimate square roots",
      "materials": ["Notebook"],
      "steps": [
        "Write numbers such as 50, 120 and 300",
        "Find the nearest perfect squares",
        "Estimate their square roots"
      ],
      "learning_outcome": "Develops estimation skills",
      "evaluation": "Accuracy of estimation (10 marks)"
    },
    {
      "sl_no": 7,
      "title": "Square Number Puzzle",
      "objective": "Solve square number puzzles",
      "materials": ["Notebook"],
      "steps": [
        "Create puzzles using square numbers",
        "Exchange puzzles with classmates",
        "Solve and explain the solution"
      ],
      "learning_outcome": "Improves problem-solving skills",
      "evaluation": "Correct solutions (10 marks)"
    },
    {
      "sl_no": 8,
      "title": "Cube Pattern Investigation",
      "objective": "Investigate patterns in cube numbers",
      "materials": ["Notebook"],
      "steps": [
        "List cubes from 1³ to 10³",
        "Observe differences between consecutive cubes",
        "Describe the pattern found"
      ],
      "learning_outcome": "Recognises patterns in cubic numbers",
      "evaluation": "Pattern explanation (10 marks)"
    },
    {
      "sl_no": 9,
      "title": "Real-Life Cube Applications",
      "objective": "Apply cube concept to real-life situations",
      "materials": ["Notebook"],
      "steps": [
        "Identify objects shaped like cubes",
        "Estimate their side lengths",
        "Calculate their approximate volume"
      ],
      "learning_outcome": "Connects cube numbers to real-life contexts",
      "evaluation": "Correct volume calculations (10 marks)"
    },
    {
      "sl_no": 10,
      "title": "Square–Cube Comparison Project",
      "objective": "Analyse the growth of squares vs cubes",
      "materials": ["Chart paper", "Markers"],
      "steps": [
        "Create a table of numbers from 1 to 10",
        "Write their squares and cubes",
        "Analyse which grows faster and explain why"
      ],
      "learning_outcome": "Understands growth patterns of powers",
      "evaluation": "Correct analysis and presentation (10 marks)"
    }
