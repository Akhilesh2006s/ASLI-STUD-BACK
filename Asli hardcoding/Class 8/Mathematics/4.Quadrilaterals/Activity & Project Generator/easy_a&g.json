  "activities_projects": [
    {
      "sl_no": 1,
      "title": "Quadrilateral Identification",
      "objective": "Identify quadrilaterals from different shapes",
      "materials": ["Notebook", "Pencil"],
      "steps": [
        "Draw five different shapes",
        "Identify which ones have four sides",
        "Label them as quadrilaterals"
      ],
      "learning_outcome": "Recognises quadrilateral shapes",
      "evaluation": "Correct identification (10 marks)"
    },
    {
      "sl_no": 2,
      "title": "Draw Different Quadrilaterals",
      "objective": "Learn types of quadrilaterals",
      "materials": ["Notebook", "Ruler"],
      "steps": [
        "Draw a rectangle, square, and parallelogram",
        "Label their sides and angles",
        "Compare their shapes"
      ],
      "learning_outcome": "Understands basic quadrilateral types",
      "evaluation": "Accuracy of drawings (10 marks)"
    },
    {
      "sl_no": 3,
      "title": "Angle Sum Activity",
      "objective": "Verify that the sum of angles in a quadrilateral is 360°",
      "materials": ["Notebook", "Protractor"],
      "steps": [
        "Draw any quadrilateral",
        "Measure all four angles",
        "Add them and verify the total"
      ],
      "learning_outcome": "Understands angle sum property",
      "evaluation": "Correct measurement and calculation (10 marks)"
    },
    {
      "sl_no": 4,
      "title": "Rectangle Property Check",
      "objective": "Observe properties of rectangles",
      "materials": ["Notebook", "Ruler", "Protractor"],
      "steps": [
        "Draw a rectangle",
        "Measure all angles",
        "Measure opposite sides"
      ],
      "learning_outcome": "Recognises rectangle properties",
      "evaluation": "Correct observation (10 marks)"
    },
    {
      "sl_no": 5,
      "title": "Square Investigation",
      "objective": "Understand properties of a square",
      "materials": ["Notebook", "Ruler"],
      "steps": [
        "Draw a square",
        "Measure all sides",
        "Check that all angles are 90°"
      ],
      "learning_outcome": "Identifies properties of a square",
      "evaluation": "Accuracy of measurements (10 marks)"
    },
    {
      "sl_no": 6,
      "title": "Diagonal Drawing",
      "objective": "Understand diagonals of quadrilaterals",
      "materials": ["Notebook", "Ruler"],
      "steps": [
        "Draw a quadrilateral",
        "Draw both diagonals",
        "Observe how they divide the shape"
      ],
      "learning_outcome": "Understands diagonals in quadrilaterals",
      "evaluation": "Correct construction (10 marks)"
    },
    {
      "sl_no": 7,
      "title": "Parallelogram Exploration",
      "objective": "Observe properties of parallelograms",
      "materials": ["Notebook", "Ruler", "Protractor"],
      "steps": [
        "Draw a parallelogram",
        "Measure opposite angles",
        "Compare opposite sides"
      ],
      "learning_outcome": "Understands parallelogram properties",
      "evaluation": "Correct observation (10 marks)"
    },
    {
      "sl_no": 8,
      "title": "Quadrilateral Sorting",
      "objective": "Classify quadrilaterals",
      "materials": ["Chart paper"],
      "steps": [
        "Write names of quadrilaterals",
        "Group them based on properties",
        "Create a classification chart"
      ],
      "learning_outcome": "Understands quadrilateral classification",
      "evaluation": "Correct grouping (10 marks)"
    },
    {
      "sl_no": 9,
      "title": "Real-Life Quadrilaterals",
      "objective": "Identify quadrilaterals in everyday objects",
      "materials": ["Notebook"],
      "steps": [
        "Look around your classroom",
        "List objects shaped like quadrilaterals",
        "Write the type of quadrilateral"
      ],
      "learning_outcome": "Connects geometry to real life",
      "evaluation": "Correct examples (10 marks)"
    },
    {
      "sl_no": 10,
      "title": "Quadrilateral Poster",
      "objective": "Summarise properties of quadrilaterals",
      "materials": ["Chart paper", "Colours"],
      "steps": [
        "Draw different quadrilaterals",
        "Write their properties",
        "Decorate and present the poster"
      ],
      "learning_outcome": "Reinforces understanding of quadrilaterals",
      "evaluation": "Presentation and accuracy (10 marks)"
    }
  ]
}
