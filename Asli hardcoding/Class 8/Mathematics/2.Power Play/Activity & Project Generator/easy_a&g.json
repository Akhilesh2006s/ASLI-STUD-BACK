      "objective": "Identify square numbers",
      "materials": ["Chart paper", "Marker"],
      "steps": [
        "Write numbers from 1 to 20",
        "Find the square of each number",
        "Highlight the perfect squares"
      ],
      "learning_outcome": "Recognises square numbers",
      "evaluation": "Accuracy of squares (10 marks)"
    },
    {
      "sl_no": 4,
      "title": "Cube Number List",
      "objective": "Understand cube numbers",
      "materials": ["Notebook"],
      "steps": [
        "Write numbers from 1 to 10",
        "Find the cube of each number",
        "List all cube numbers clearly"
      ],
      "learning_outcome": "Identifies cube numbers",
      "evaluation": "Correct cube calculations (10 marks)"
    },
    {
