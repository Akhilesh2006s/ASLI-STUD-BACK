      "title": "Exponent Match Game",
      "objective": "Understand powers and exponents",
      "materials": ["Notebook", "Pencil"],
      "steps": [
        "Write numbers with powers like 2^3, 3^2, 5^2",
        "Find their expanded forms",
        "Match them with their answers"
      ],
      "learning_outcome": "Recognises exponent notation",
      "evaluation": "Correct matching of powers (10 marks)"
    },
    {
      "sl_no": 2,
      "title": "Power Expansion Practice",
      "objective": "Expand powers into repeated multiplication",
      "materials": ["Notebook"],
      "steps": [
        "Write five powers such as 4^2, 3^3, 2^4",
        "Expand them using repeated multiplication",
        "Write the final value"
      ],
      "learning_outcome": "Understands concept of exponent expansion",
      "evaluation": "Correct expansion (10 marks)"
    },
    {
      "sl_no": 3,
