        "Verify the answer"
      ],
      "learning_outcome": "Applies exponent knowledge",
      "evaluation": "Correct solution (10 marks)"
    },
    {
      "sl_no": 10,
      "title": "Real-Life Powers",
      "objective": "Relate exponents to real-life examples",
      "materials": ["Notebook"],
      "steps": [
