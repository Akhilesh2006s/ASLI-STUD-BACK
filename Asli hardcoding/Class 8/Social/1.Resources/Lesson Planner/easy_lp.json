    "Explain renewable and non-renewable resources",
    "Understand the concept of resource conservation",
    "Explain sustainable development",
    "Recognize the importance of responsible use of resources"
  ],
  "lesson_plan": [
    {
      "period": 1,
      "title": "Introduction to Resources",
      "topics_covered": [
        "Meaning of resources",
        "Utility and value of resources",
        "Examples of resources in daily life"
      ],
      "teaching_strategy": [
        "Brainstorming activity about everyday resources",
        "Teacher explanation with examples",
        "Question and answer discussion"
      ],
      "student_activities": [
        "List resources used in daily life",
        "Discuss how these resources help people"
      ],
      "assessment": ["Oral questioning", "Student responses"]
    },
    {
