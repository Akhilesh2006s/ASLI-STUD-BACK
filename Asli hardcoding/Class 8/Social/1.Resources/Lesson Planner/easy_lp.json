      "title": "Types of Resources",
      "topics_covered": [
        "Natural resources",
        "Human-made resources",
        "Human resources"
      ],
      "teaching_strategy": [
        "Concept explanation using examples",
        "Comparison chart on the board"
      ],
      "student_activities": [
        "Classify examples of resources into categories",
        "Create a small chart in notebooks"
      ],
      "assessment": ["Notebook checking", "Short oral questions"]
    },
    {
      "period": 3,
      "title": "Natural Resources",
      "topics_covered": [
