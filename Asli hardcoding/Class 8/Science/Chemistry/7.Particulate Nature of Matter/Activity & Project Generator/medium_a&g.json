{
  "class": "Class 8",
  "subject": "Science",
  "chapter": "Particulate Nature of Matter",
  "difficulty": "Medium",
  "activities_projects": [
    {
      "sl_no": 1,
      "title": "Comparing Solid and Liquid Shapes",
      "objective": "Understand difference between shape properties of solids and liquids",
      "materials": ["Stone", "Water", "Glass container", "Bottle"],
      "steps": [
        "Place a stone in different containers",
        "Observe whether the shape changes",
        "Pour water into the same containers",
        "Compare the shape of water in each container"
      ],
      "learning_outcome": "Students identify that solids have fixed shape while liquids take container shape",
      "evaluation": "Comparison explanation (10 marks)"
    },
    {
      "sl_no": 2,
      "title": "Salt Dissolution Observation",
      "objective": "Understand dissolution and particle distribution",
      "materials": ["Water", "Salt", "Glass", "Spoon"],
      "steps": [
        "Fill a glass with water",
        "Add one teaspoon of salt",
        "Stir the solution",
        "Taste a small drop carefully"
      ],
      "learning_outcome": "Students understand that dissolved particles spread evenly",
      "evaluation": "Explanation of uniform distribution (10 marks)"
    },
    {
      "sl_no": 3,
      "title": "Evaporation Observation",
      "objective": "Observe liquid changing to gas",
      "materials": ["Water", "Plate"],
      "steps": [
        "Pour water into a shallow plate",
        "Place it in sunlight",
        "Observe water level after several hours"
      ],
      "learning_outcome": "Students learn about evaporation process",
      "evaluation": "Observation report (10 marks)"
    },
    {
      "sl_no": 4,
      "title": "Diffusion of Food Color",
      "objective": "Study particle movement in liquids",
      "materials": ["Water", "Food color", "Glass"],
      "steps": [
        "Fill a glass with water",
        "Add a drop of food color",
        "Observe color spreading without stirring"
      ],
      "learning_outcome": "Students understand diffusion",
      "evaluation": "Observation description (10 marks)"
    },
    {
      "sl_no": 5,
      "title": "Compressibility of Air",
      "objective": "Understand compressibility of gases",
      "materials": ["Plastic bottle", "Balloon"],
      "steps": [
        "Attach balloon to bottle",
        "Press the bottle",
        "Observe balloon behavior"
      ],
      "learning_outcome": "Students learn that air can be compressed",
      "evaluation": "Explanation (10 marks)"
    },
    {
      "sl_no": 6,
      "title": "Heating Water Observation",
      "objective": "Understand boiling process",
      "materials": ["Water", "Beaker", "Heat source"],
      "steps": [
        "Heat water slowly",
        "Observe bubble formation",
        "Record temperature if thermometer available"
      ],
      "learning_outcome": "Students understand boiling point",
      "evaluation": "Observation notes (10 marks)"
    },
    {
      "sl_no": 7,
      "title": "Liquid Flow Investigation",
      "objective": "Observe flow property of liquids",
      "materials": ["Water", "Oil", "Inclined surface"],
      "steps": [
        "Pour water on an inclined surface",
        "Repeat with oil",
        "Compare flow behavior"
      ],
      "learning_outcome": "Students understand liquids flow easily",
      "evaluation": "Comparison report (10 marks)"
    },
    {
      "sl_no": 8,
      "title": "Particle Packing Model",
      "objective": "Visualize particle arrangement",
      "materials": ["Marbles", "Box"],
      "steps": [
        "Arrange marbles tightly in a box",
        "Shake the box gently",
        "Observe movement"
      ],
      "learning_outcome": "Students visualize particle arrangement in solids",
      "evaluation": "Model explanation (10 marks)"
    },
    {
      "sl_no": 9,
      "title": "Air Occupies Space",
      "objective": "Demonstrate that air occupies space",
      "materials": ["Glass", "Water bowl", "Tissue paper"],
      "steps": [
        "Place tissue inside glass",
        "Invert glass into water",
        "Observe tissue condition"
      ],
      "learning_outcome": "Students understand air occupies space",
      "evaluation": "Experiment explanation (10 marks)"
    },
    {
      "sl_no": 10,
      "title": "Perfume Diffusion Test",
      "objective": "Observe gas diffusion",
      "materials": ["Perfume spray"],
      "steps": [
        "Spray perfume in one corner of the room",
        "Observe how smell spreads"
      ],
      "learning_outcome": "Students understand gas particles move freely",
      "evaluation": "Observation explanation (10 marks)"
    }
  ]
}
