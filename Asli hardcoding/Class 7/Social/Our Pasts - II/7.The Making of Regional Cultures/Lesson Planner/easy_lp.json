                "Folk tales and songs"
            ],
            "teaching_strategy": [
                "Read a short story",
                "Show pictures of writers or songs"
            ],
            "student_activities": [
                "Name regional languages",
                "Share one story they liked"
            ],
            "assessment": [
                "Participation",
                "Notebook notes"
            ]
        },
        {
