      ],
      "student_activities": [
        "Draw a map showing journey points and events",
        "Explain challenges and how they were overcome"
      ],
      "assessment": ["Map accuracy", "Oral explanation"]
    },
    {
      "period": 4,
      "title": "Problem Solving and Critical Thinking",
      "topics_covered": [
        "Unexpected difficulties",
        "Teamwork and planning",
        "Balancing curiosity with caution"
      ],
      "teaching_strategy": [
