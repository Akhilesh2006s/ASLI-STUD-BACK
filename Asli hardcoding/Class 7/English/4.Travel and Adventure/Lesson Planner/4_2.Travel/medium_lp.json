      ],
      "teaching_strategy": [
        "Class discussion on travel experiences",
        "Prediction activity based on title and illustrations"
      ],
      "student_activities": [
        "Predict what the journey might involve",
        "Discuss possible challenges characters could face"
      ],
      "assessment": ["Oral discussion", "Class participation"]
    },
    {
      "period": 2,
      "title": "Character Analysis",
      "topics_covered": [
        "Traits of narrator and companions",
        "Motivations and decisions",
        "Reactions to travel situations"
      ],
      "teaching_strategy": [
        "Guided reading",
        "Teacher-led character analysis prompts"
      ],
      "student_activities": [
        "List character traits with textual evidence",
        "Discuss how traits influence decisions during travel"
      ],
      "assessment": ["Written trait list", "Oral discussion"]
    },
    {
      "period": 3,
      "title": "Journey Mapping",
      "topics_covered": [
