        "Moral of the story",
        "Themes of teamwork and curiosity"
      ],
      "teaching_strategy": [
        "Discussion and guided reflective writing"
      ],
      "student_activities": [
        "Write a paragraph reflecting on lessons learned",
        "Share experiences from personal travel"
      ],
      "assessment": ["Paragraph writing", "Class sharing"]
    },
    {
      "period": 6,
      "title": "Language and Grammar",
      "topics_covered": [
        "Advanced vocabulary from story",
        "Compound words and conditional sentences",
        "Sentence construction practice"
      ],
      "teaching_strategy": [
        "Grammar exercises and revision quiz"
      ],
      "student_activities": [
        "Form compound words and use them in sentences",
        "Complete conditional sentences about travel"
      ],
      "assessment": ["Worksheet activity", "Quiz"]
    }
  ],
