                "Peer-to-peer naming drill"
            ]
        },
        {
            "period": 2,
            "title": "SSS and SAS Criteria",
            "topics_covered": [
                "Side-Side-Side (SSS) rule",
                "Side-Angle-Side (SAS) rule",
                "Identifying the 'Included Angle'"
            ],
            "teaching_strategy": [
                "Comparative drawing",
                "Criteria checklist method"
            ],
            "student_activities": [
                "",
                "Identify which pair of triangles are congruent using SSS or SAS from a worksheet",
                "Draw triangles based on SAS data to see if they are identical"
            ],
            "assessment": [
                "Problem-solving worksheet",
                "Exit slip: 'Why is the angle in SAS called included?'"
            ]
        }
    ],
    "teaching_aids": [
        "Place value charts (for similarity comparison)",
